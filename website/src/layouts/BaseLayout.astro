---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: "sk" | "en";
}

const {
  title,
  description = "Teologická paradigma liturgických a hymnologických prameňov v protestantskom prostredí strednej Európy",
  lang = "sk",
} = Astro.props;

const siteTitle = "TEPALIT Digital Companion";
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
// Derive canonical URL from Astro.site (configured in astro.config.mjs)
// + the request pathname. When Astro.site is unset (dev preview, custom
// proxy, etc.), fall back to the live request origin so canonical/OG
// tags reflect the actual host the visitor is on rather than a hard-
// coded localhost.
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.url.origin).toString();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:locale" content={lang === "en" ? "en_GB" : "sk_SK"} />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Citation / scholarship hints -->
    <meta name="citation_publisher" content="APVV-24-0484 (TEPALIT)" />
    <meta name="DC.publisher" content="Slovak Research and Development Agency, APVV-24-0484" />
    <meta name="DC.rights" content="CC BY 4.0 (content); MIT (code)" />

    <title>{fullTitle}</title>
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50
             focus:rounded focus:bg-ink focus:px-4 focus:py-2 focus:text-parchment focus:no-underline"
    >
      Skip to content
    </a>

    <Header />
    <!-- `data-pagefind-body` scopes the Pagefind search index to page content
         only (header, footer, and the search modal itself are excluded). -->
    <main id="main" class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer />
  </body>
</html>
