---
const navItems = [
  { href: "/", label: "Domov", labelEn: "Home" },
  { href: "/timeline/", label: "Chronológia", labelEn: "Timeline" },
  { href: "/taxonomy/", label: "Taxonómia", labelEn: "Taxonomy" },
  { href: "/synoptikon/", label: "Synoptikon", labelEn: "Synoptikon" },
  { href: "/hymn-pairs/", label: "Hymno-páry", labelEn: "Hymn Pairs" },
  { href: "/network/", label: "Sieť", labelEn: "Network" },
  { href: "/sources/", label: "Pramene", labelEn: "Sources" },
  { href: "/chapter/", label: "Kapitola", labelEn: "Chapter" },
] as const;
const base = import.meta.env.BASE_URL;
---

<header class="sticky top-0 z-40 border-b border-parchment-400/50 bg-parchment-50/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-wide items-center justify-between px-6 py-3">
    <!-- Logo / title -->
    <a href={base + "/"} class="group flex items-center gap-3 no-underline">
      <span class="text-2xl text-gold" aria-hidden="true">&#x2720;</span>
      <span class="font-display text-lg font-semibold tracking-tight text-ink transition-colors group-hover:text-burgundy">
        TEPALIT
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 md:flex" aria-label="Main navigation">
      {navItems.map((item) => (
        <a
          href={base + item.href}
          title={item.labelEn}
          class="rounded-md px-3 py-1.5 font-sans text-sm font-medium text-ink-400
                 no-underline transition-colors hover:bg-parchment-300/50 hover:text-ink"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="rounded-md p-2 text-ink-400 transition-colors hover:bg-parchment-300/50 md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>

  <!-- Mobile nav (hidden by default) -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-parchment-400/30 bg-parchment-50 px-6 py-4 md:hidden"
    aria-label="Mobile navigation"
  >
    {navItems.map((item) => (
      <a
        href={base + item.href}
        title={item.labelEn}
        class="block rounded-md px-3 py-2 font-sans text-sm font-medium text-ink-400
               no-underline transition-colors hover:bg-parchment-300/50 hover:text-ink"
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  if (btn && menu) {
    btn.addEventListener("click", () => {
      const expanded = btn.getAttribute("aria-expanded") === "true";
      btn.setAttribute("aria-expanded", String(!expanded));
      btn.setAttribute("aria-label", expanded ? "Open menu" : "Close menu");
      menu.classList.toggle("hidden");
    });
  }
</script>
