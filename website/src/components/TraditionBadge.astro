---
/**
 * Tradition colour badge — inline pill component.
 * Used throughout the site wherever a tradition label appears.
 */
interface Props {
  tradition: "LUTHERAN" | "UTRAQUIST" | "UNITY";
  size?: "sm" | "md";
}

const { tradition, size = "sm" } = Astro.props;

const labels: Record<string, { sk: string; en: string; css: string }> = {
  LUTHERAN: { sk: "Luteránska", en: "Lutheran", css: "badge-lutheran" },
  UTRAQUIST: { sk: "Utrakvistická", en: "Utraquist", css: "badge-utraquist" },
  UNITY: { sk: "Jednota bratská", en: "Unity", css: "badge-unity" },
};

const info = labels[tradition];
---

<span
  class:list={[info.css, size === "md" && "px-3 py-1 text-sm"]}
  title={info.en}
>
  {info.sk}
</span>
