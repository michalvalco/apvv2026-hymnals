      "Granular extension of the Csepregi 2003 ARG essay. Conclusion: Stöckel did not write the Pentapolitana, and it was at most tactically tolerated by Ferdinand I, never formally approved. Prešov university press; ILL.",
    url: "https://real.mtak.hu/44271",
    chapter_relevance: "§3, §4.1, §4.2",
    language: "DE",
  },
  {
    id: "Augustinova_2011",
    type: "secondary",
    tier: 2,
    status: "ill-pending",
    full_citation:
      "Augustínová, Eva. Cithara sanctorum bibliografia. Martin: Slovenská národná knižnica, 2011.",
    description_sk:
      "Komplexný bibliografický súpis všetkých známych vydaní Cithary Sanctorum cez 19. a začiatok 20. storočia. Foundational pre §6/§5 recepčnú naratívu. SNK Martin; ILL.",
    description_en:
      "Comprehensive bibliographic survey of all known Cithara Sanctorum editions through the 19th and early 20th centuries. Foundational for §6/§5 reception narrative. SNK Martin; ILL.",
    chapter_relevance: "§5",
    language: "SK",
  },
  {
    id: "GresovaSekelska_2016",
    type: "secondary",
    tier: 2,
    status: "collegial-expected",
    full_citation:
      "Grešová-Sekelská, Adriana. \"Notované vydania Cithary Sanctorum v 17. storočí – opis a komparácia pamiatok.\" Slovenská hudba 42, no. 3 (2016): 261–274.",
    description_sk:
      "Textovo-kritický popis a komparatívna analýza notovaných Levočských vydaní 17. storočia. Komplementárna štúdia ku Ruščin 2019. Najlepšie získať kolegiálne od Adriany — TEPALIT spolupracovníčka.",
    description_en:
      "Text-critical description and comparative analysis of the notated 17th-century Levoča editions. Companion to Ruščin 2019. Best obtained collegially through TEPALIT collaboration channels.",
    chapter_relevance: "§5",
    language: "SK",
  },
  {
    id: "Leaver_2024",
    type: "secondary",
    tier: 2,
    status: "ill-pending",
    full_citation:
      "Leaver, Robin A., ed. A New Song We Now Begin: Celebrating the Half Millennium of Lutheran Hymnals 1524–2024. Lutheran Quarterly Books. Minneapolis: Fortress, 2024. 304 pp. ISBN 978-1-5064-8744-1.",
    description_sk:
      "Najrecentnejší kolektívny statement hymnologicko-konfesionálnej tézy v polmiléniovom rozsahu. Najbližší existujúci paralel ku TEPALIT-projektu pre wittenbersko-saské strane. Pre §7-štýlové rámcovanie.",
    description_en:
      "The most recent collective statement of the hymnological-confessional thesis at half-millennium scope. The closest existing parallel to the TEPALIT project for the Wittenberg/Saxon side. For §7-style framing.",
    url: "https://fortresspress.com/store/product/9781506487441",
    chapter_relevance: "§7",
    language: "EN",
  },
  // ── Tier 2 — Master Plan v0.3 newly added ──
  {
    id: "Soucek_1933",
    type: "secondary",
    tier: 2,
    status: "ill-pending",
    full_citation:
      "Souček, J. B. Theologie výkladů kralické šestidílky. Praha: Královská česká společnost nauk, 1933.",
    description_sk:
      "Monografia 1933 analyzujúca teologické poznámky v Kralickej Biblii — záver: Bratrstvo bolo „viac kalvinistické ako luteránske v teológii“. §4.4 prerekvizita pridaná v Master Plan v0.3 (z Hroboň 2011 fn. 18). Akvizícia: Kramerius NDK ČR / Národní knihovna Praha / ETF UK Praha.",
    description_en:
      "1933 monograph analysing theological notes in the Kralice Bible — concludes the Brethren were 'more Calvinist than Lutheran in their theology'. §4.4 prerequisite added in Master Plan v0.3 (from Hroboň 2011 fn. 18). Acquisition: Kramerius NDK ČR / National Library Prague / ETF UK Prague.",
    chapter_relevance: "§4.4",
    language: "CZ",
  },
  // ── Secondary recommendations from lit-gap report ──
  {
    id: "Holeton_BRRP",
    type: "secondary",
    tier: 1,
    status: "ill-pending",
    full_citation:
      "Holeton, David R. \"The Evolution of Utraquist Eucharistic Liturgy: A Textual Study.\" Bohemian Reformation and Religious Practice 2 (1998): 97–126. + further BRRP papers (vols. 6, 7, 8).",
    description_sk:
      "Open-access. Jediná súvislá textovo-kritická analýza utrakvistického eucharistického ordo proti luteránskym, katolíckym a švédskym paralelám. Metodologický model pre lex-orandi čítanie. Dostupné na brrp.org.",
    description_en:
      "Open-access. The only sustained text-critical analysis of the Utraquist eucharistic ordo against Lutheran, Catholic, and Swedish parallels. Methodological model for lex-orandi reading. Available at brrp.org.",
    url: "http://brrp.org/proceedings/brrp2/holeton.pdf",
    chapter_relevance: "§4.1, §4.2",
    language: "EN",
  },
  {
    id: "Karant_Nunn_1997",
    type: "secondary",
    tier: 2,
    status: "ill-pending",
    full_citation:
      "Karant-Nunn, Susan C. The Reformation of Ritual: An Interpretation of Early Modern Germany. London/New York: Routledge, 1997. 282 pp. ISBN 978-0-415-11337-3.",
    description_sk:
      "Foundational metodologický precedens pre kapitolovú lex-orandi optiku. Pokrýva eucharistický rítus, krst, churching, pokánie, pohreb. Pre §2 a §4.1.",
    description_en:
      "Foundational methodological precedent for the chapter's lex-orandi optic. Covers the Eucharistic rite, baptism, churching, repentance, burial. For §2 and §4.1.",
    chapter_relevance: "§2, §4.1",
    language: "EN",
  },
  {
    id: "Lambert_2017",
    type: "secondary",
    tier: 2,
    status: "ill-pending",
    full_citation:
      "Lambert, Erin. Singing the Resurrection: Body, Community, and Belief in Reformation Europe. New York: Oxford University Press, 2017.",
    description_sk:
      "Surfaced via Puff 2018. Priamo relevantná pre kapitolovú tézu hymnody ako konfesionálnej formácie. Pre §7.",
    description_en:
      "Surfaced via Puff 2018. Directly relevant to the chapter's thesis about hymnody as confessional formation. For §7.",
    url: "https://global.oup.com/academic/product/9780190649890",
    chapter_relevance: "§7",
    language: "EN",
  },
];

const tierColor: Record<BibTier, string> = {
  1: "bg-epistemic-factual/15 text-epistemic-factual",
  2: "bg-gold/15 text-gold-dark",
  3: "bg-burgundy/15 text-burgundy",
};
const statusBadge: Record<BibStatus, { sk: string; en: string; class: string }> = {
  done: {
    sk: "Hotové",
    en: "Done",
    class: "bg-epistemic-factual/15 text-epistemic-factual",
  },
  "ill-pending": {
    sk: "ILL / akvizícia čaká",
    en: "ILL pending",
    class: "bg-gold/10 text-gold-dark",
  },
  "collegial-expected": {
    sk: "Kolegiálne očakávané",
    en: "Collegial channel",
    class: "bg-unity/15 text-unity",
  },
  "tier-3-scaffold": {
    sk: "Tier 3 — len scaffolding",
    en: "Tier 3 — scaffolding only",
    class: "bg-burgundy/10 text-burgundy",
  },
};

// Sort: recently_added first, then by tier (1 → 2 → 3), then alphabetical.
const sortedBibEntries = bibEntries.slice().sort((a, b) => {
  if (a.recently_added && !b.recently_added) return -1;
  if (b.recently_added && !a.recently_added) return 1;
  if (a.tier !== b.tier) return a.tier - b.tier;
  return a.id.localeCompare(b.id);
});

const recentlyAddedCount = bibEntries.filter((e) => e.recently_added).length;

const allReferenced = Array.from(referencedIds).sort();
const curatedReferenced = allReferenced
  .filter((id) => curated[id])
  .sort((a, b) => {
    const ta = typeOrder[curated[a].type];
    const tb = typeOrder[curated[b].type];
    return ta !== tb ? ta - tb : a.localeCompare(b);
  });
const stubReferenced = allReferenced.filter((id) => !curated[id]).sort();

const typeLabels: Record<CuratedSource["type"], { sk: string; en: string }> = {
  primary: { sk: "Primárny prameň", en: "Primary source" },
  edition: { sk: "Kritická edícia", en: "Critical edition" },
  secondary: { sk: "Sekundárna literatúra", en: "Secondary literature" },
};
---

<BaseLayout
  title="Pramene — register"
  description="Source register for the TEPALIT digital companion. Anchored entries for every source ID referenced by the hymn-pair dossier and evidence layer."
  lang="sk"
>
  <!-- Header -->
  <section class="bg-ink-800 px-6 py-16 text-parchment">
    <div class="mx-auto max-w-content text-center">
      <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-gold">
        Source Register · Citation Targets
      </p>
      <h1 class="mt-3 text-section-title font-display font-bold text-parchment-100">
        Pramene
      </h1>
      <p class="mx-auto mt-2 max-w-prose font-sans text-sm uppercase tracking-wider text-parchment-500" lang="en">
        Sources
      </p>
      <p class="mx-auto mt-6 max-w-prose text-parchment-400">
        Register kotviacich identifikátorov pre každý prameň, na ktorý odkazuje
        hymno-párový dossier alebo dôkazová vrstva. Pre úplnú bibliografickú
        evidenciu so statusmi prístupnosti pozrite Source_Index.md v repozitári.
      </p>
      <p class="mx-auto mt-3 max-w-prose font-sans text-sm italic text-parchment-500" lang="en">
        Anchored register for every source the hymn-pair dossier or evidence layer
        references. For full bibliographic data with accessibility status, see
        Source_Index.md in the repository.
      </p>
      <a
        href={`${REPO_BLOB}/Sources/Source_Index.md`}
        class="mt-6 inline-flex items-center gap-2 rounded-md bg-gold/15 px-4 py-2 font-sans text-sm font-medium text-gold no-underline hover:bg-gold/25"
      >
        Source_Index.md &#x2192; GitHub
      </a>
    </div>
  </section>

  <!-- ═══════════ AUDIT-STORY / VERIFICATION-DISCIPLINE PANEL ═══════════ -->
  <section class="mx-auto max-w-content px-6 pt-10">
    <aside class="rounded-lg border-l-4 border-epistemic-factual/60 bg-parchment-100/40 p-5">
      <p class="font-sans text-[10px] font-semibold uppercase tracking-wider text-ink-300">
        Verifikačná disciplína / <span lang="en">Verification discipline</span>
      </p>
      <p class="mt-2 text-sm leading-relaxed text-ink-400">
        Každý prameň v tomto registri prešiel nezávislou verifikáciou voči
        katalógu vydavateľstva, indexu časopisu, DOI alebo repozitárnemu
        záznamu. Audit z 9. mája 2026 odhalil <strong>~20 % chybovosť</strong>
        v pôvodnej AI-generovanej rešerši — hlavne autorské zámeny v tesne
        prepojených bibliografických klastroch a neoverené ISBN/strany. Žiadna
        citácia z AI rešerše nevstupuje do <code class="font-mono text-xs">Sources/*.md</code>
        bez verifikačného kroku.
      </p>
      <p class="mt-3 font-sans text-xs italic leading-relaxed text-ink-300" lang="en">
        Every source in this register has been independently verified against
        a publisher catalogue, journal index, DOI, or repository entry. The
        9 May 2026 audit revealed a <strong>~20% error rate</strong> in the
        original AI-generated reconnaissance — chiefly author swaps in tightly
        bibliographically-linked clusters and unverified ISBNs/page ranges.
        No AI-generated citation enters
        <code class="font-mono text-xs">Sources/*.md</code> without an
        independent verification step.
      </p>
      <p class="mt-3 font-sans text-xs text-ink-300">
        Plný metodologický opis: <a href={`${baseN}/papers/methods/`} class="text-burgundy hover:underline">metodologická štúdia</a>
        (tri osi dôvery v lex-orandi datasetoch).
      </p>
    </aside>
  </section>

  <!-- Curated entries -->
  <section class="mx-auto max-w-content px-6 py-10">
    <h2 class="text-section-title text-ink">Aktívne používané pramene</h2>
    <p class="mt-1 font-sans text-sm italic text-ink-300" lang="en">
      Sources in active scholarly use
    </p>
    <p class="mt-3 text-sm text-ink-400">
      Pramene s vlastným popisom, na ktoré sa priamo odvoláva hymno-párový
      argument. Stabilné kotvy ako <code class="font-mono text-xs">/sources/#&lt;ID&gt;</code>.
    </p>

    <div class="mt-8 space-y-5">
      {
        curatedReferenced.map((id) => {
          const c = curated[id];
          const tl = typeLabels[c.type];
          return (
            <article
              class="card scroll-mt-24"
              id={id}
            >
              <div class="flex flex-wrap items-start justify-between gap-2">
                <div>
                  <code class="font-mono text-xs font-semibold text-burgundy">
                    {id}
                  </code>
                  <span class="ml-2 rounded-full bg-parchment-300/50 px-2 py-0.5 font-sans text-[10px] text-ink-400">
                    {tl.sk} · <span class="italic" lang="en">{tl.en}</span>
                  </span>
                </div>
                {c.url && (
                  <a
                    href={c.url}
                    class="font-sans text-xs text-burgundy hover:underline"
                    rel="noopener"
                  >
                    Online &#x2197;
                  </a>
                )}
              </div>
              <p class="mt-2 font-serif text-sm text-ink">{c.full_citation}</p>
              <p class="mt-3 text-sm text-ink-400">{c.description_sk}</p>
              <p class="mt-2 font-sans text-xs italic text-ink-300" lang="en">
                {c.description_en}
              </p>
              {(() => {
                const usedIn = pairsForSource(id);
                if (usedIn.length === 0) {
                  return (
                    <p class="mt-3 font-sans text-[10px] uppercase tracking-wider text-ink-300" lang="en">
                      <a
                        href={`${baseN}/hymn-pairs/`}
                        class="hover:text-burgundy"
                      >
                        See hymn-pair dossier &#x2192;
                      </a>
                    </p>
                  );
                }
                return (
                  <div class="mt-3 rounded-md bg-parchment-100/70 p-3">
                    <p class="font-sans text-[10px] uppercase tracking-wider text-ink-300" lang="en">
                      Used in {usedIn.length} {usedIn.length === 1 ? "hymn pair" : "hymn pairs"}
                    </p>
                    <ul class="mt-1 flex flex-wrap gap-2 font-mono text-[11px]">
                      {usedIn.map((pid) => (
                        <li>
                          <a
                            href={`${baseN}/hymn-pairs/#${pid}`}
                            class="text-burgundy hover:underline"
                          >
                            {pid}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                );
              })()}
            </article>
          );
        })
      }
    </div>
  </section>

  <!-- ═══════════ ANNOTATED CHAPTER BIBLIOGRAPHY ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-10">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <h2 class="text-section-title text-ink">Anotovaná bibliografia kapitoly</h2>
      {recentlyAddedCount > 0 && (
        <span class="rounded-full bg-epistemic-factual/15 px-3 py-1 font-sans text-[11px] font-semibold uppercase tracking-wider text-epistemic-factual">
          {recentlyAddedCount} nedávno pridané /
          <span class="italic" lang="en">recently added</span>
        </span>
      )}
    </div>
    <p class="mt-1 font-sans text-sm italic text-ink-300" lang="en">
      Annotated chapter bibliography — beyond the hymn-pair dossier
    </p>
    <p class="mt-3 max-w-prose text-sm text-ink-400">
      Pramene, na ktoré sa kapitola opiera mimo hymno-párového dossiera —
      Tier-priorita matica z auditovanej Literature-Gap reportu, Phase-2
      priority list z Master Plan v0.3, sekundárne odporúčania. Hotové
      záznamy sú v <code class="font-mono text-xs">Sources/*.md</code> v
      repozitári; ostatné majú akvizičný status.
    </p>
    <p class="mt-2 max-w-prose font-sans text-xs italic text-ink-300" lang="en">
      Sources the chapter draws on beyond the hymn-pair dossier — the
      tier-priority matrix from the audited Literature-Gap Report, the Phase-2
      priority list from Master Plan v0.3, and secondary recommendations.
      Completed entries live in <code class="font-mono text-xs">Sources/*.md</code>
      in the repository; others carry an acquisition-status flag.
    </p>

    <ol class="mt-8 space-y-4">
      {sortedBibEntries.map((entry, idx) => {
        const sb = statusBadge[entry.status];
        const tl = typeLabels[entry.type];
        return (
          <li
            id={entry.id}
            class:list={[
              "card scroll-mt-24",
              entry.recently_added && "border-l-4 border-epistemic-factual/60",
            ]}
          >
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <code class="font-mono text-xs font-semibold text-burgundy">
                  {entry.id}
                </code>
                <span
                  class:list={[
                    "ml-2 rounded-full px-2 py-0.5 font-sans text-[10px] font-semibold",
                    tierColor[entry.tier],
                  ]}
                >
                  Tier {entry.tier}
                </span>
                <span
                  class:list={[
                    "ml-1 rounded-full px-2 py-0.5 font-sans text-[10px] font-medium",
                    sb.class,
                  ]}
                >
                  {sb.sk} <span class="opacity-70" lang="en">/ {sb.en}</span>
                </span>
                <span class="ml-1 rounded-full bg-parchment-300/50 px-2 py-0.5 font-sans text-[10px] text-ink-400">
                  {tl.sk}
                </span>
                {entry.recently_added && (
                  <span class="ml-1 rounded-full bg-epistemic-factual/20 px-2 py-0.5 font-sans text-[10px] font-semibold text-epistemic-factual">
                    &#x2728; nedávno pridané
                  </span>
                )}
              </div>
              {entry.url && (
                <a
                  href={entry.url}
                  class="font-sans text-xs text-burgundy hover:underline"
                  rel="noopener"
                >
                  Online &#x2197;
                </a>
              )}
            </div>

            <p class="mt-3 font-serif text-sm text-ink">
              {entry.full_citation}
            </p>

            <p class="mt-3 text-sm leading-relaxed text-ink-400">
              {entry.description_sk}
            </p>
            <p class="mt-2 font-sans text-xs italic leading-relaxed text-ink-300" lang="en">
              {entry.description_en}
            </p>

            <div class="mt-3 flex flex-wrap gap-2 font-mono text-[11px]">
              <span class="rounded bg-parchment-100/70 px-2 py-0.5 text-ink-400">
                Kapitola: <strong>{entry.chapter_relevance}</strong>
              </span>
              <span class="rounded bg-parchment-100/70 px-2 py-0.5 text-ink-400">
                Lang: <strong>{entry.language}</strong>
              </span>
              {entry.source_note_path && (
                <a
                  href={`${REPO_BLOB}/${entry.source_note_path}`}
                  class="rounded bg-burgundy/10 px-2 py-0.5 text-burgundy hover:bg-burgundy/20"
                  rel="noopener"
                >
                  Sources/*.md &#x2197;
                </a>
              )}
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <!-- Stub entries -->
  {stubReferenced.length > 0 && (
    <section class="mx-auto max-w-content px-6 py-8 pb-20">
      <h2 class="text-section-title text-ink">Ostatné odkazy</h2>
      <p class="mt-1 font-sans text-sm italic text-ink-300" lang="en">
        Other referenced IDs
      </p>
      <p class="mt-3 text-sm text-ink-400">
        Identifikátory prameňov, na ktoré sa data vrstva odvoláva, no zatiaľ
        nemajú vlastný popis. Pre plnú bibliografiu pozrite Source_Index.md.
      </p>
      <ul class="mt-6 grid gap-2 sm:grid-cols-2">
        {
          stubReferenced.map((id) => (
            <li id={id} class="scroll-mt-24 rounded-md border border-parchment-300/50 bg-parchment-50 px-3 py-2">
              <code class="font-mono text-xs font-semibold text-ink">{id}</code>
              <a
                href={`${REPO_BLOB}/Sources/Source_Index.md`}
                class="ml-2 font-sans text-[11px] text-ink-300 hover:text-burgundy"
              >
                see Source_Index.md &#x2197;
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  )}
</BaseLayout>
