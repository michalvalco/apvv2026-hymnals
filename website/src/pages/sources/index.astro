const base = import.meta.env.BASE_URL;
const baseN = base.replace(/\/$/, "");
const REPO_BLOB = "https://github.com/michalvalco/apvv2026-hymnals/blob/main";

// ── Collect every source ID referenced by the data layer ──
// Track per-source the list of pair IDs that cite it (via citation_chain
// or via evidence-row source_collection_id paired with a pair).
const referencedIds = new Set<string>();
const pairsBySource: Record<string, Set<string>> = {};

const addPairToSource = (sourceId: string, pairId: string) => {
  if (!pairsBySource[sourceId]) pairsBySource[sourceId] = new Set<string>();
  pairsBySource[sourceId].add(pairId);
};

const allPairs = getHymnPairs();
const allEvidence = getHymnicEvidence();
const evidenceById = new Map(allEvidence.map((e) => [e.text_id, e] as const));

for (const pair of allPairs) {
  // Sources cited directly in citation_chain
  if (pair.citation_chain) {
    pair.citation_chain
      .split(";")
      .map((s) => s.trim())
      .filter(Boolean)
      .forEach((id) => {
        referencedIds.add(id);
        addPairToSource(id, pair.pair_id);
      });
  }
  // Sources reached via the pair's evidence rows (source_collection_id)
  for (const textId of [pair.source_text_id, pair.receptor_text_id]) {
    if (!textId) continue;
    const ev = evidenceById.get(textId);
    if (ev?.source_collection_id) addPairToSource(ev.source_collection_id, pair.pair_id);
  }
}

for (const ev of allEvidence) {
  if (ev.source_collection_id) referencedIds.add(ev.source_collection_id);
}

const pairsForSource = (id: string): string[] =>
  pairsBySource[id] ? Array.from(pairsBySource[id]).sort() : [];

