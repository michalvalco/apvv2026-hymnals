---
import BaseLayout from "../layouts/BaseLayout.astro";
import EpistemicLegend from "../components/EpistemicLegend.astro";

const base = import.meta.env.BASE_URL;

const sections = [
  {
    href: "/register-shift/",
    titleSk: "Posun registra — interaktívne",
    titleEn: "Register Shift — interactive",
    description: "Vlajkový interaktívny nález: tá istá eucharistická náuka v stúpajúcom registri — od mierneho k polemicky ostrému — naprieč CB 1575 · AC 1581 · BA 1585 · CS 1636. Potiahnite register a sledujte, ako manducatio impiorum prelomí mlčanie.",
    icon: "&#x1F39A;&#xFE0F;",
    status: "live" as const,
  },
  {
    href: "/timeline/",
    titleSk: "Chronológia",
    titleEn: "Confessional Streams",
    description: "Interaktívna časová os troch konfesionálnych tradícií — dokumenty, kancionály, liturgické poriadky a politické medzníky od husitských vojen po Bielu horu.",
    icon: "&#x23F3;",
    status: "live" as const,
  },
  {
    href: "/taxonomy/",
    titleSk: "Teologická taxonómia",
    titleEn: "Theological Taxonomy",
    description: "20 teologických sub-loci naprieč štyrmi hlavnými oblasťami. Konfesionálne pozície, hymnicko-liturgické dôkazy a viacjazyčný terminologický aparát.",
    icon: "&#x1F4D6;",
    status: "live" as const,
  },
  {
    href: "/synoptikon/",
    titleSk: "Synoptikon",
    titleEn: "Parallel Text Viewer",
    description: "Paralelné čítanie kľúčových textov: konfesijné dokumenty, hymny a liturgické poriadky vedľa seba s farebne zvýraznenými teologickými rozdielmi.",
    icon: "&#x1F4DC;",
    status: "live" as const,
  },
  {
    href: "/hymn-pairs/",
    titleSk: "Hymno-páry — dôkazové dossier",
    titleEn: "Hymn-Pair Dossier",
    description: "Empirické jadro pre §5: hymno-páry doloženej luteranizácie aj regionálnej luteránskej kontinuity (BA → CS). Každý záznam má argument, citačný reťazec a tri osi dôvery (epistemika, sila dôkazu, vlastná verifikácia).",
    icon: "&#x1F517;",
    status: "live" as const,
  },
  {
    href: "/network/",
    titleSk: "Intertextuálna sieť",
    titleEn: "Intertextual Network",
    description: "Sieťový graf vzťahov medzi textami — výpožičky, polemiky, zdieľané biblické citácie a liturgické paralely naprieč tradíciami.",
    icon: "&#x1F578;",
    status: "live" as const,
  },
  {
    href: "/papers/",
    titleSk: "Štúdie",
    titleEn: "Companion Papers",
    description: "Dve predbežné publikácie odvodené z prípravy kapitoly: štúdia pre Historia Ecclesiastica o intra-kódexovej eucharistickej stratifikácii (PAIR_006) a metodologická štúdia o trojosovom rámci dôvery v lex-orandi datasetoch.",
    icon: "&#x1F4D1;",
    status: "live" as const,
  },
  {
    href: "/chapter/",
    titleSk: "Kapitola",
    titleEn: "Hypertext Monograph",
    description: "Monografická kapitola ako hypertextový dokument — každá citácia odkazuje na primárny prameň, každý teologický argument je prepojený s dôkazmi.",
    icon: "&#x270D;",
    status: "coming-soon" as const,
  },
];
---

<BaseLayout
  title="TEPALIT Digital Companion"
  description="Lex orandi, lex credendi — What was sung reveals what was believed. Interactive companion to the TEPALIT monograph on dogmatic comparison of Lutheranism and Czech confessions."
  lang="sk"
>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative overflow-hidden bg-ink-800 px-6 py-24 text-parchment md:py-36">
    <!-- Decorative gradient overlay -->
    <div
      class="absolute inset-0 opacity-30"
      style="background: radial-gradient(ellipse at 30% 50%, rgba(212,168,67,0.25) 0%, transparent 60%),
             radial-gradient(ellipse at 70% 30%, rgba(139,35,50,0.15) 0%, transparent 50%),
             radial-gradient(ellipse at 50% 80%, rgba(46,139,139,0.15) 0%, transparent 50%);"
      aria-hidden="true"
    ></div>

    <div class="relative mx-auto max-w-content text-center">
      <!-- Ornamental cross -->
      <div class="mb-6 text-gold/60 text-4xl" aria-hidden="true">&#x2720;</div>

      <!-- Tagline -->
      <p class="mb-4 font-sans text-sm font-medium uppercase tracking-[0.2em] text-gold">
        Lex orandi, lex credendi
      </p>

      <!-- Title -->
      <h1 class="text-hero-title font-display font-bold text-parchment-100">
        Čo sa spievalo, <br class="hidden sm:block" />
        prezrádza, čomu sa verilo
      </h1>

      <!-- Subtitle -->
      <p class="mx-auto mt-6 max-w-prose text-hero-subtitle font-serif font-light text-parchment-400">
        Dogmatická komparácia luteranizmu a českých konfesií v zrkadle
        liturgických a hymnologických prameňov (16.–18. storočie)
      </p>

      <!-- EN subtitle -->
      <p class="mx-auto mt-4 max-w-prose font-sans text-sm text-parchment-500" lang="en">
        Dogmatic comparison of Lutheranism and Czech confessions through liturgical
        and hymnological sources (16th–18th century)
      </p>

      <!-- Tradition colour indicators -->
      <div class="mt-10 flex items-center justify-center gap-8">
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-lutheran" aria-hidden="true"></span>
          <span class="font-sans text-xs text-parchment-400">Luteranizmus</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-utraquist" aria-hidden="true"></span>
          <span class="font-sans text-xs text-parchment-400">Utrakvizmus</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="h-3 w-3 rounded-full bg-unity" aria-hidden="true"></span>
          <span class="font-sans text-xs text-parchment-400">Jednota bratská</span>
        </div>
      </div>

      <!-- Phase tracker -->
      <div class="mt-10 flex flex-col items-center gap-2">
        <p class="font-sans text-[11px] uppercase tracking-wider text-parchment-500" lang="en">
          TEPALIT phase 2 of 4 · 2026 · Primary data collection
        </p>
        <div class="flex gap-1.5" role="img" aria-label="Project phase 2 of 4">
          <span class="h-1 w-12 rounded-full bg-gold"></span>
          <span class="h-1 w-12 rounded-full bg-gold"></span>
          <span class="h-1 w-12 rounded-full bg-parchment-700/40"></span>
          <span class="h-1 w-12 rounded-full bg-parchment-700/40"></span>
        </div>
      </div>

      <!-- CTA -->
      <div class="mt-10">
        <a
          href="#explore"
          class="inline-flex items-center gap-2 rounded-lg bg-gold/20 px-6 py-3
                 font-sans text-sm font-medium text-gold no-underline
                 transition-colors hover:bg-gold/30"
        >
          Preskúmajte pramene
          <span aria-hidden="true">&darr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════ PROJECT CONTEXT ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-16">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h2 class="text-section-title text-ink">O projekte</h2>
        <p class="mt-4 text-ink-400 leading-relaxed">
          Táto stránka je interaktívnym sprievodcom monografickej kapitoly
          vznikajúcej v rámci grantového projektu APVV-24-0484
          <span class="text-latin">(TEPALIT)</span>. Kapitola skúma, ako sa
          dogmatické rozdiely a konvergencie medzi augsburským luteranizmom,
          utrakvizmom a Jednotou bratskou prejavovali v liturgickej praxi
          a hymnografii.
        </p>
        <p class="mt-4 text-ink-400 leading-relaxed">
          Primárna optika: <em class="text-latin">lex orandi, lex credendi</em> —
          to, čo sa spievalo a modlilo, odhaľuje, čomu sa verilo, často
          vernejšie než normatívne konfesionálne dokumenty.
        </p>
      </div>
      <div lang="en">
        <h2 class="text-section-title text-ink">About the project</h2>
        <p class="mt-4 text-ink-400 leading-relaxed">
          This site is an interactive companion to a monograph chapter produced
          under the APVV-24-0484 grant
          (<span class="text-latin">TEPALIT</span>). The chapter examines how
          dogmatic differences and convergences between Augsburg Lutheranism,
          Utraquism, and the Unity of Brethren manifested in liturgical practice
          and hymnography across 16th–18th-century Central Europe.
        </p>
        <p class="mt-4 text-ink-400 leading-relaxed">
          Primary lens: <em class="text-latin">lex orandi, lex credendi</em> —
          what was sung and prayed reveals what was believed.
        </p>
      </div>
    </div>
  </section>

  <div class="ornament-rule"></div>

  <!-- ═══════════ FOUR LOCI OVERVIEW ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-8">
    <h2 class="text-center text-section-title text-ink">Štyri teologické loci</h2>
    <p class="mx-auto mt-3 max-w-prose text-center font-sans text-sm text-ink-300" lang="en">
      Four theological loci that structure the comparative analysis
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      <div class="card border-t-4 border-gold">
        <h3 class="font-display text-lg font-semibold text-ink">§4.1 Eucharistia</h3>
        <p class="mt-1 font-sans text-xs text-ink-300 text-latin">De Sacramentis</p>
        <p class="mt-3 text-sm text-ink-400">
          Reálna prítomnosť vs. duchovná prítomnosť vs. symbolizmus.
          Prijímanie pod obojím. Obetný charakter liturgie.
        </p>
      </div>
      <div class="card border-t-4 border-burgundy">
        <h3 class="font-display text-lg font-semibold text-ink">§4.2 Ekleziológia</h3>
        <p class="mt-1 font-sans text-xs text-ink-300 text-latin">De Ecclesia</p>
        <p class="mt-3 text-sm text-ink-400">
          Cirkev, služba, apoštolská postupnosť — oblasť najostrejších
          inštitucionálnych rozdielov.
        </p>
      </div>
      <div class="card border-t-4 border-unity">
        <h3 class="font-display text-lg font-semibold text-ink">§4.3 Soteriológia</h3>
        <p class="mt-1 font-sans text-xs text-ink-300 text-latin">De Salute et Ethica</p>
        <p class="mt-3 text-sm text-ink-400">
          <span class="text-latin">Sola fide</span> vs. eticko-praktické akcenty
          českej reformácie. Posvätenie, disciplína v Jednote.
        </p>
      </div>
      <div class="card border-t-4 border-parchment-500">
        <h3 class="font-display text-lg font-semibold text-ink">§4.4 Písmo a tradícia</h3>
        <p class="mt-1 font-sans text-xs text-ink-300 text-latin">De Scriptura et Traditione</p>
        <p class="mt-3 text-sm text-ink-400">
          Prístupy k biblickej autorite a patristickým prameňom.
          Bibličtina ako zdieľané liturgické médium.
        </p>
      </div>
    </div>
  </section>

  <div class="ornament-rule"></div>

  <!-- ═══════════ EXPLORE SECTIONS ═══════════ -->
  <section id="explore" class="mx-auto max-w-content px-6 py-8">
    <h2 class="text-center text-section-title text-ink">Interaktívne nástroje</h2>
    <p class="mx-auto mt-3 max-w-prose text-center font-sans text-sm text-ink-300" lang="en">
      Interactive tools — digital humanities meets Reformation-era theology
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((s) =>
        s.status === "coming-soon" ? (
          <div class="card relative cursor-default opacity-70">
            <span class="absolute right-4 top-4 rounded-full bg-parchment-300 px-2 py-0.5
                         font-sans text-xs text-ink-300">
              Pripravujeme
            </span>
            <div class="text-3xl" aria-hidden="true" set:html={s.icon} />
            <h3 class="mt-3 font-display text-lg font-semibold text-ink">
              {s.titleSk}
            </h3>
            <p class="mt-0.5 font-sans text-xs text-ink-300">{s.titleEn}</p>
            <p class="mt-3 text-sm text-ink-400">{s.description}</p>
          </div>
        ) : (
          <a
            href={base + s.href}
            class="card group relative no-underline"
          >
            <div class="text-3xl" aria-hidden="true" set:html={s.icon} />
            <h3 class="mt-3 font-display text-lg font-semibold text-ink group-hover:text-burgundy">
              {s.titleSk}
            </h3>
            <p class="mt-0.5 font-sans text-xs text-ink-300">{s.titleEn}</p>
            <p class="mt-3 text-sm text-ink-400">{s.description}</p>
          </a>
        ),
      )}
    </div>
  </section>

  <div class="ornament-rule"></div>

  <!-- ═══════════ EPISTEMIC STATUS ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-8 pb-20">
    <h2 class="text-center text-section-title text-ink">Epistemická transparentnosť</h2>
    <p class="mx-auto mt-3 max-w-prose text-center text-sm text-ink-400">
      Každá vizualizácia na tejto stránke rozlišuje medzi overenými faktami,
      odbornými interpretáciami a otvorenými otázkami. Táto transparentnosť je
      základným princípom projektu.
    </p>
    <div class="mx-auto mt-8 max-w-2xl">
      <EpistemicLegend />
    </div>
  </section>
</BaseLayout>
