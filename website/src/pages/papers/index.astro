---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const baseN = base.replace(/\/$/, "");

interface PaperEntry {
  href: string;
  status: { sk: string; en: string };
  statusColor: "green" | "amber" | "grey";
  titleSk: string;
  titleEn: string;
  subtitleSk: string;
  subtitleEn: string;
  authorSk: string;
  authorEn: string;
  venueSk: string;
  venueEn: string;
  language: string;
  approxLength: string;
  shortDescriptionSk: string;
  shortDescriptionEn: string;
}

const papers: PaperEntry[] = [
  {
    href: "/papers/theologos/",
    status: { sk: "Finálna verzia · Historia Ecclesiastica", en: "Final draft · Historia Ecclesiastica" },
    statusColor: "amber",
    titleSk:
      "Cithara Sanctorum (1636) zviazaná: intra-kódexová konfesionálna stratifikácia v exemplári Lyceálnej knižnice v Bratislave",
    titleEn:
      "The Cithara Sanctorum (1636) Bound In: Intra-Codex Confessional Stratification in the Bratislava Lyceal Library Exemplar",
    subtitleSk: "Agenda Česká 1581 + Bystrická agenda 1585",
    subtitleEn: "Agenda Česká 1581 + Bystrická agenda 1585",
    authorSk: "Michal Valčo (sólo)",
    authorEn: "Michal Valčo (solo)",
    venueSk:
      "Historia Ecclesiastica (Prešovská univerzita) · Scopus",
    venueEn:
      "Historia Ecclesiastica (University of Prešov) · Scopus",
    language: "British English",
    approxLength: "~9 800 slov · 41 poznámok pod čiarou · 29 bibliografických záznamov",
    shortDescriptionSk:
      "Komplementárny nález k luteranizačnej téze: konfesionálne ostrenie eucharistickej teológie prebieha aj vnútri jedného luteránskeho kódexu — od mierneho českého tlačeného registra (AC 1581) k tvrdšiemu slovenskému rukopisnému registru (BA 1585). Anchored on PAIR_006.",
    shortDescriptionEn:
      "A complementary finding to the Lutheranisation thesis: confessional sharpening of Eucharistic theology operates within a single Lutheran codex — from a moderate Czech printed register (AC 1581) to a sharper Slovak manuscript register (BA 1585). Anchored on PAIR_006.",
  },
  {
    href: "/papers/methods/",
    status: { sk: "Osnova v0.1 · termín drafty TBD", en: "Outline v0.1 · drafting target TBD" },
    statusColor: "grey",
    titleSk:
      "Tri osi dôvery v digitálnej konfesionálnej hymnológii",
    titleEn:
      "Three Trust Axes for Digital Confessional Hymnology",
    subtitleSk:
      "Dekompozícia epistemického statusu, sily dôkazu a verifikácie v lex orandi datasetoch",
    subtitleEn:
      "Decomposing Epistemic Status, Evidentiary Strength, and Verification in Lex Orandi Datasets",
    authorSk: "Michal Valčo (predbežne sólo)",
    authorEn: "Michal Valčo (provisional sole author)",
    venueSk:
      "Cieľ: Digital Humanities Quarterly (DHQ) + Journal of Open Humanities Data (JOHD) — koordinované dvojité odoslanie",
    venueEn:
      "Target: Digital Humanities Quarterly (DHQ) + Journal of Open Humanities Data (JOHD) — coordinated double submission",
    language: "English",
    approxLength: "~6 500–7 500 slov (cieľ); plný text v príprave",
    shortDescriptionSk:
      "Metodologický príspevok pre digitálnu humanistiku v oblasti konfesionálnej teológie: tri ortogonálne osi dôvery — epistemický status × sila dôkazu × stav vlastnej verifikácie — ktoré jednoosové DH vizualizácie zlučujú do nerozlíšiteľnosti.",
    shortDescriptionEn:
      "A methodological contribution to digital-humanities datasets in confessional theology: three orthogonal trust axes — epistemic status × evidentiary strength × verification status — that single-axis DH visualisations conflate into indistinguishability.",
  },
];

const statusBadgeClass: Record<PaperEntry["statusColor"], string> = {
  green: "bg-epistemic-factual/15 text-epistemic-factual",
  amber: "bg-gold/15 text-gold-dark",
  grey: "bg-parchment-300/50 text-ink-300",
};
---

<BaseLayout
  title="Štúdie — TEPALIT companion papers"
  description="Two preliminary publications spinning off from the TEPALIT chapter: the Theologos paper on intra-codex confessional stratification (PAIR_006) and the methods paper on three trust axes for digital confessional hymnology."
  lang="sk"
>
  <!-- ═══════════ HERO ═══════════ -->
  <section class="bg-ink-800 px-6 py-16 text-parchment">
    <div class="mx-auto max-w-content text-center">
      <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-gold">
        Companion publications · APVV-24-0484
      </p>
      <h1 class="mt-3 text-section-title font-display font-bold text-parchment-100">
        Štúdie
      </h1>
      <p class="mx-auto mt-2 max-w-prose font-sans text-sm uppercase tracking-wider text-parchment-500" lang="en">
        Companion papers
      </p>
      <p class="mx-auto mt-6 max-w-prose text-parchment-400">
        Dve predbežné publikácie odvodené z prípravy monografickej kapitoly:
        substantívna štúdia pre časopis <em>Theologos</em> (PAIR_006 ako pracovný
        príklad) a metodologická štúdia pre digitálnu humanistiku (trojosový
        rámec dôvery v lex-orandi datasetoch). Plné texty zostávajú v
        <code class="font-mono text-xs">Drafts/</code> v repo do odoslania.
      </p>
      <p class="mx-auto mt-3 max-w-prose font-sans text-sm italic text-parchment-500" lang="en">
        Two preliminary publications spinning off from the chapter's preparation:
        a substantive paper for <em>Theologos</em> (with PAIR_006 as worked example)
        and a methods paper for the digital-humanities community (the three-axis
        trust framework for lex-orandi datasets). Full drafts remain in
        <code class="font-mono text-xs">Drafts/</code> in the repo until submission.
      </p>
    </div>
  </section>

  <!-- ═══════════ PAPER CARDS ═══════════ -->
  <section class="mx-auto max-w-wide px-6 py-12">
    <div class="grid gap-6 md:grid-cols-2">
      {
        papers.map((p) => (
          <article class="card flex h-full flex-col">
            <header>
              <span
                class:list={[
                  "inline-block rounded-full px-2 py-0.5 font-sans text-[10px] font-semibold uppercase tracking-wider",
                  statusBadgeClass[p.statusColor],
                ]}
              >
                {p.status.sk}
              </span>
              <p class="mt-1 font-sans text-[10px] italic uppercase tracking-wider text-ink-300" lang="en">
                {p.status.en}
              </p>
              <h2 class="mt-4 font-display text-lg font-semibold leading-snug text-ink">
                <a href={baseN + p.href} class="hover:text-burgundy">
                  {p.titleSk}
                </a>
              </h2>
              <p class="mt-1 font-sans text-xs italic leading-snug text-ink-300" lang="en">
                {p.titleEn}
              </p>
              {p.subtitleSk && (
                <p class="mt-2 font-display text-sm font-medium text-ink-400">
                  {p.subtitleSk}
                </p>
              )}
            </header>

            <dl class="mt-4 grid grid-cols-[max-content_1fr] gap-x-3 gap-y-1 font-sans text-[11px]">
              <dt class="text-ink-300">Autor</dt>
              <dd class="text-ink-400">{p.authorSk}</dd>
              <dt class="text-ink-300">Cieľové miesto</dt>
              <dd class="text-ink-400">{p.venueSk}</dd>
              <dt class="text-ink-300">Jazyk</dt>
              <dd class="text-ink-400">{p.language}</dd>
              <dt class="text-ink-300">Rozsah</dt>
              <dd class="text-ink-400">{p.approxLength}</dd>
            </dl>

            <p class="mt-4 flex-1 text-sm leading-relaxed text-ink-400">
              {p.shortDescriptionSk}
            </p>
            <p class="mt-3 font-sans text-xs italic leading-relaxed text-ink-300" lang="en">
              {p.shortDescriptionEn}
            </p>

            <footer class="mt-5 border-t border-parchment-300/40 pt-3">
              <a
                href={baseN + p.href}
                class="inline-flex items-center gap-1 rounded-md bg-burgundy/10 px-3 py-1.5 font-sans text-xs font-medium text-burgundy no-underline transition-colors hover:bg-burgundy/20"
              >
                Otvoriť stránku štúdie / <span class="italic" lang="en">Open paper page</span>
                &#x2192;
              </a>
            </footer>
          </article>
        ))
      }
    </div>
  </section>

  <div class="ornament-rule"></div>

  <!-- ═══════════ HOW THESE RELATE TO THE CHAPTER ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-12">
    <h2 class="text-section-title text-ink">Vzťah ku kapitole</h2>
    <p class="mt-1 font-sans text-sm italic text-ink-300" lang="en">
      Relationship to the monograph chapter
    </p>

    <p class="mt-4 text-sm leading-relaxed text-ink-400">
      Obe štúdie sú predbežné publikácie. Theologos štúdia rozvíja jeden
      špecifický nález (PAIR_006 — intra-kódexová eucharistická stratifikácia
      v bratislavskom exemplári) ako samostatnú prácu pre reformačno-historickú
      auditóriu; v kapitole TEPALIT-monografie sa tento nález stáva
      sub-komponentom §5 (Transfer a recepcia). Metodologická štúdia formalizuje
      trojosový rámec dôvery, ktorý je viditeľný na celom webe — najmä na
      <a href={`${baseN}/hymn-pairs/`} class="text-burgundy">stránke
      hymno-párov</a> — a otvára ho pre širšiu DH komunitu.
    </p>
    <p class="mt-3 font-sans text-xs italic leading-relaxed text-ink-300" lang="en">
      Both papers are preliminary publications. The Theologos paper develops one
      specific finding (PAIR_006 — intra-codex Eucharistic stratification in the
      Bratislava exemplar) as a stand-alone piece for a Reformation-history
      audience; in the TEPALIT monograph chapter the finding becomes a
      sub-component of §5 (Transfer and Reception). The methods paper formalises
      the three-axis trust framework that is visible across the entire site —
      most prominently on the <a href={`${baseN}/hymn-pairs/`} class="text-burgundy">hymn-pairs
      page</a> — and opens it to the broader DH community.
    </p>
  </section>

  <!-- ═══════════ FUNDER + LICENSE ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-10 pb-20">
    <h2 class="text-section-title text-ink">Licencia a financovanie</h2>
    <p class="mt-1 font-sans text-sm italic text-ink-300" lang="en">
      Licence and funding
    </p>
    <p class="mt-4 text-sm text-ink-400">
      Obe štúdie sú výstupom projektu APVV-24-0484 (TEPALIT). Po odoslaní do
      časopisu sa licencia plných textov riadi vydavateľskou zmluvou; abstrakt,
      bibliografia a citačný popis na týchto stránkach sa publikujú pod
      <a href="https://creativecommons.org/licenses/by/4.0/" class="text-burgundy" rel="noopener">CC BY 4.0</a>.
    </p>
    <p class="mt-3 font-sans text-xs italic text-ink-300" lang="en">
      Both papers are outputs of project APVV-24-0484 (TEPALIT). After journal
      submission the licence of the full texts follows the publisher's contract;
      the abstracts, bibliographies, and citation summaries on these pages are
      published under <a href="https://creativecommons.org/licenses/by/4.0/" class="text-burgundy" rel="noopener">CC BY 4.0</a>.
    </p>
  </section>
</BaseLayout>
