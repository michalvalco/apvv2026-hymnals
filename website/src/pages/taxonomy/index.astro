---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EpistemicLegend from "../../components/EpistemicLegend.astro";
import {
  getParentLoci,
  getSubLoci,
  getPositionsForLocus,
  getTermsForLocus,
  getHymnicFunctions,
  PRIORITY_ORDER,
} from "../../data/taxonomy";

const parentLoci = getParentLoci().sort(
  (a, b) => PRIORITY_ORDER[a.priority] - PRIORITY_ORDER[b.priority],
);

const base = import.meta.env.BASE_URL;

const locusAccents: Record<string, string> = {
  L1: "border-gold",
  L2: "border-burgundy",
  L3: "border-unity",
  L4: "border-parchment-500",
};

const priorityColors: Record<string, string> = {
  HIGHEST: "bg-utraquist/15 text-utraquist-dark",
  HIGH: "bg-lutheran/15 text-lutheran-dark",
  MEDIUM: "bg-parchment-300 text-ink-400",
  LOW: "bg-parchment-200 text-ink-300",
};

const hymnicFunctions = getHymnicFunctions()
  .sort((a, b) => b.theological_weight - a.theological_weight);
---

<BaseLayout
  title="Teologická taxonómia"
  description="20 teologických sub-loci naprieč štyrmi hlavnými oblasťami — konfesionálne pozície, hymnicko-liturgické dôkazy a viacjazyčný terminologický aparát."
  lang="sk"
>
  <!-- Header -->
  <section class="bg-ink-800 px-6 py-16 text-parchment">
    <div class="mx-auto max-w-content text-center">
      <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-gold">
        Scholarly Reference
      </p>
      <h1 class="mt-3 text-section-title font-display font-bold text-parchment-100">
        Teologická taxonómia
      </h1>
      <p class="mx-auto mt-4 max-w-prose text-parchment-400">
        4 teologické loci &times; 5 sub-loci = 20 kategórií komparatívnej analýzy.
        Každý sub-locus dokumentuje konfesionálne pozície troch tradícií,
        terminologický aparát v štyroch jazykoch a hymnicko-liturgické dôkazy.
      </p>
      <p class="mx-auto mt-2 max-w-prose font-sans text-sm text-parchment-500">
        4 theological loci &times; 5 sub-loci = 20 categories of comparative analysis
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-content px-6 py-12">
    <div class="mb-10">
      <EpistemicLegend compact />
    </div>

    <!-- Loci grid -->
    {parentLoci.map((parent) => {
      const subs = getSubLoci(parent.locus_code);
      const accent = locusAccents[parent.locus_code] ?? "border-parchment-400";

      return (
        <section class="mb-14">
          <div class={`card ${accent} mb-6`}>
            <div class="flex flex-wrap items-baseline gap-3">
              <span class="font-mono text-sm text-ink-300">{parent.chapter_section}</span>
              <h2 class="font-display text-xl font-semibold text-ink">
                {parent.locus_name_sk}
              </h2>
              <span class="text-latin text-sm text-ink-300">{parent.locus_name_la}</span>
            </div>
            <p class="mt-1 font-sans text-sm text-ink-300">{parent.locus_name_en}</p>
            <p class="mt-3 text-sm text-ink-400">{parent.description_en}</p>
          </div>

          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b-2 border-parchment-400 text-left font-sans text-xs uppercase tracking-wider text-ink-300">
                  <th class="py-2 pr-4">Kód</th>
                  <th class="py-2 pr-4">Sub-locus</th>
                  <th class="py-2 pr-4 text-latin">Latin</th>
                  <th class="py-2 pr-4 text-center">Pozície</th>
                  <th class="py-2 pr-4 text-center">Termíny</th>
                  <th class="py-2 pr-4 text-center">Priorita</th>
                </tr>
              </thead>
              <tbody>
                {subs.map((sub) => {
                  const posCount = getPositionsForLocus(sub.locus_code).length;
                  const termCount = getTermsForLocus(sub.locus_code).length;

                  return (
                    <tr class="border-b border-parchment-300/50 transition-colors hover:bg-parchment-100">
                      <td class="py-3 pr-4">
                        <a
                          href={`${base}/taxonomy/${sub.locus_code.toLowerCase().replace(".", "-")}/`}
                          class="font-mono text-sm font-medium text-burgundy"
                        >
                          {sub.locus_code}
                        </a>
                      </td>
                      <td class="py-3 pr-4">
                        <a
                          href={`${base}/taxonomy/${sub.locus_code.toLowerCase().replace(".", "-")}/`}
                          class="font-medium text-ink no-underline hover:text-burgundy"
                        >
                          {sub.locus_name_sk}
                        </a>
                        <p class="mt-0.5 font-sans text-xs text-ink-300 line-clamp-2">
                          {sub.description_en}
                        </p>
                      </td>
                      <td class="py-3 pr-4 text-latin text-xs text-ink-300">
                        {sub.locus_name_la}
                      </td>
                      <td class="py-3 pr-4 text-center font-mono text-sm">
                        {posCount > 0 ? posCount : (
                          <span class="text-ink-200">&mdash;</span>
                        )}
                      </td>
                      <td class="py-3 pr-4 text-center font-mono text-sm">
                        {termCount > 0 ? termCount : (
                          <span class="text-ink-200">&mdash;</span>
                        )}
                      </td>
                      <td class="py-3 pr-4 text-center">
                        <span class={`inline-block rounded-full px-2 py-0.5 font-sans text-xs font-medium ${priorityColors[sub.priority]}`}>
                          {sub.priority}
                        </span>
                      </td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </section>
      );
    })}

    <div class="ornament-rule"></div>

    <!-- Hymnic functions reference -->
    <section class="mb-14">
      <h2 class="font-display text-xl font-semibold text-ink">
        Hymnicko-liturgické funkcie
      </h2>
      <p class="mt-1 font-sans text-sm text-ink-300">
        How theology manifests in hymns — 10 function types with theological weights
      </p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {hymnicFunctions.map((fn) => (
          <div class="card">
            <div class="flex items-baseline justify-between">
              <h3 class="font-sans text-sm font-semibold text-ink">
                {fn.function_name_sk}
                <span class="ml-1 font-normal text-ink-300">/ {fn.function_name_en}</span>
              </h3>
              <span class="ml-2 shrink-0 font-mono text-xs text-ink-300">
                w={fn.theological_weight.toFixed(1)}
              </span>
            </div>
            <p class="mt-2 text-xs text-ink-400">{fn.description_en}</p>
            <p class="mt-2 font-sans text-xs text-ink-300">
              <strong class="text-ink-400">Markers:</strong> {fn.detection_markers}
            </p>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
