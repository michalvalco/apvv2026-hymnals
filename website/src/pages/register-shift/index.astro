  <!-- ═══════════ SCOPED STYLES ═══════════ -->
  <style>
    /* ── Scrubber track ── */
    .rs-track { height: 56px; }
    .rs-rail {
      position: absolute; left: 0; right: 0; top: 26px; height: 8px;
      border-radius: 9999px;
      background: linear-gradient(90deg, #E8C872 0%, #D4A843 30%, #B5344A 60%, #8B2332 100%);
      box-shadow: inset 0 1px 2px rgba(0,0,0,0.15);
    }
    .rs-fc { position: absolute; top: 0; transform: translateX(-50%); pointer-events: none; }
    .rs-fc-line { display:block; width: 2px; height: 38px; margin: 0 auto;
      background: repeating-linear-gradient(#A68230, #A68230 3px, transparent 3px, transparent 6px); }
    .rs-fc-label { display:block; margin-top: 2px; font-family: ui-monospace, monospace;
      font-size: 9px; font-weight: 700; color: #A68230; white-space: nowrap; }
    .rs-tick {
      position: absolute; top: 18px; transform: translateX(-50%); z-index: 3;
      display:flex; flex-direction: column; align-items:center; gap: 14px;
      background: none; border: none; cursor: pointer; padding: 0;
    }
    .rs-tick-dot { width: 14px; height: 14px; border-radius: 9999px;
      background: var(--tone); border: 2px solid #F5F0E8; box-shadow: 0 0 0 1px rgba(0,0,0,0.15);
      transition: transform .15s ease; }
    .rs-tick:hover .rs-tick-dot, .rs-tick:focus-visible .rs-tick-dot { transform: scale(1.3); }
    .rs-tick-label { font-family: ui-monospace, monospace; font-size: 10px; font-weight: 700;
      color: #7C7367; white-space: nowrap; }
    /* range input sits over the rail, transparent track, visible thumb */
    .rs-range {
      position: absolute; left: -2px; right: -2px; top: 16px; width: calc(100% + 4px); z-index: 2;
      margin: 0; background: transparent; -webkit-appearance: none; appearance: none; cursor: grab;
    }
    .rs-range:active { cursor: grabbing; }
    .rs-range:focus { outline: none; }
    .rs-range::-webkit-slider-runnable-track { height: 28px; background: transparent; }
    .rs-range::-moz-range-track { height: 28px; background: transparent; }
    .rs-range::-webkit-slider-thumb {
      -webkit-appearance: none; appearance: none; width: 26px; height: 28px;
      border-radius: 6px; background: #1A1611; border: 3px solid #F5F0E8;
      box-shadow: 0 2px 6px rgba(0,0,0,0.35); margin-top: 0;
    }
    .rs-range::-moz-range-thumb {
      width: 26px; height: 28px; border-radius: 6px; background: #1A1611;
      border: 3px solid #F5F0E8; box-shadow: 0 2px 6px rgba(0,0,0,0.35);
    }
    .rs-range:focus-visible::-webkit-slider-thumb { box-shadow: 0 0 0 3px rgba(212,168,67,0.7); }
    .rs-range:focus-visible::-moz-range-thumb { box-shadow: 0 0 0 3px rgba(212,168,67,0.7); }

    /* ── Codex strata ── */
    .codex-stratum { cursor: pointer; transition: opacity .2s ease; }
    .codex-stratum:hover, .codex-stratum:focus-visible { opacity: 0.88; outline: none; }
    .codex-stratum.is-active { filter: drop-shadow(0 3px 6px rgba(0,0,0,0.3)); }
    .codex-stratum.is-dim { opacity: 0.4; }

    /* ── Silence reveal ── */
    .silence-reveal {
      display: grid; grid-template-rows: 0fr; opacity: 0;
      transition: grid-template-rows .55s ease, opacity .55s ease;
    }
    .silence-reveal > * { overflow: hidden; min-height: 0; }
    .silence-reveal.is-open { grid-template-rows: 1fr; opacity: 1; }

    @media (prefers-reduced-motion: reduce) {
      .rs-meter, .silence-reveal, #rs-mand-clause, #rs-mand-clause-en { transition: none !important; }
    }
  </style>

  <!-- ═══════════ CONTROLLER ═══════════ -->
  <script is:inline>
    (function () {
      const dataEl = document.getElementById("rs-data");
      if (!dataEl) return;
      const DATA = JSON.parse(dataEl.textContent);
      const stations = DATA.stations;
      const chart = DATA.chart;
      const range = document.getElementById("rs-range");

      const xForPos = (p) => chart.x0 + (p / 100) * (chart.x1 - chart.x0);
      const yForReg = (p) => chart.yBot - (p / 100) * (chart.yBot - chart.yTop);
      const toneHex = { irenic: "#2E8B8B", moderate: "#D4A843", sharp: "#8B2332" };

      const $ = (id) => document.getElementById(id);
      const els = {
        year: $("rs-year"), kind: $("rs-kind"), short: $("rs-short"), full: $("rs-full"),
        register: $("rs-register"), verbatim: $("rs-verbatim"), verbatimEn: $("rs-verbatim-en"),
        mandBox: $("rs-mand-box"), mandStatus: $("rs-mand-status"),
        mandClause: $("rs-mand-clause"), mandClauseEn: $("rs-mand-clause-en"),
        gloss: $("rs-gloss"), glossEn: $("rs-gloss-en"), cite: $("rs-cite"), link: $("rs-link"),
        meter: $("rs-meter"), meterPct: $("rs-meter-pct"),
        playhead: $("rs-playhead"), playdot: $("rs-playdot"), panel: $("rs-panel"),
      };

      function nearest(v) {
        let best = stations[0], bestD = Infinity;
        for (const s of stations) {
          const d = Math.abs(s.pos - v);
          if (d < bestD) { bestD = d; best = s; }
        }
        return best;
      }

      function render(v) {
        const s = nearest(v);
        const hex = toneHex[s.tone];
        // panel identity
        els.short.textContent = s.short;
        els.full.textContent = s.full;
        els.year.textContent = String(s.year);
        els.kind.textContent = s.kindEn;
        els.register.textContent = s.registerSk;
        els.verbatim.textContent = s.verbatim;
        els.verbatimEn.textContent = s.verbatimEn;
        els.gloss.textContent = s.glossSk;
        els.glossEn.textContent = s.glossEn;
        els.cite.textContent = s.cite;
        els.link.textContent = s.link.labelSk + " →";
        els.link.setAttribute("href", (DATA.base || "") + s.link.href);
        // panel accent
        els.panel.style.borderColor = hex;
        els.panel.style.background = hexToRgba(hex, 0.06);
        // manducatio
        if (s.manducatio) {
          els.mandStatus.textContent = "✓ explicitné / explicit";
          els.mandStatus.style.color = "#8B2332";
          els.mandBox.style.background = "rgba(139,35,50,0.08)";
          els.mandClause.textContent = "„" + (s.manducatioClause || "") + "“";
          els.mandClauseEn.textContent = s.manducatioClauseEn || "";
          els.mandClause.style.opacity = "1";
          els.mandClauseEn.style.opacity = "1";
        } else {
          els.mandStatus.textContent = "— mlčanie (zámerné) / deliberate silence";
          els.mandStatus.style.color = "#7C7367";
          els.mandBox.style.background = "rgba(0,0,0,0.03)";
          els.mandClause.style.opacity = "0";
          els.mandClauseEn.style.opacity = "0";
        }
        // meter (continuous with handle)
        els.meter.style.width = v + "%";
        els.meterPct.textContent = Math.round(v) + "%";
        // playhead + dot (dot follows the register curve)
        const px = xForPos(v);
        els.playhead.setAttribute("x1", px);
        els.playhead.setAttribute("x2", px);
        els.playdot.setAttribute("cx", px);
        els.playdot.setAttribute("cy", yForReg(v));
        // highlight active tick
        document.querySelectorAll(".rs-tick").forEach((t) => {
          const on = Math.abs(Number(t.dataset.pos) - s.pos) < 0.5;
          t.style.opacity = on ? "1" : "0.6";
        });
      }

      function hexToRgba(hex, a) {
        const n = parseInt(hex.slice(1), 16);
        return `rgba(${(n >> 16) & 255},${(n >> 8) & 255},${n & 255},${a})`;
      }

      range.addEventListener("input", () => render(Number(range.value)));

      // station ticks jump the handle
      document.querySelectorAll(".rs-tick").forEach((t) => {
        t.addEventListener("click", () => {
          range.value = t.dataset.pos;
          render(Number(range.value));
        });
      });

      render(Number(range.value));

      // ── Bound codex ──
      const codexCopy = {
        ac: {
          eyebrow: "Tlač · mierny register / Print · moderate",
          title: "Agenda Česká 1581",
          body: "Tlačená česko-luteránska agenda zostavená wittenberskými ordinovanými duchovnými. „Tělo a krev“ bez prívlastkov; hodné prijímanie kotví vo viere v slová ustanovenia. Mlčí o manducatio impiorum. Eucharistický rítus: Benka 2024, pp. 131–150.",
          bodyEn: "A printed Czech-Lutheran agenda compiled by Wittenberg-ordained clergy. “Body and blood” without adjectives; worthy reception grounded in faith in the words of institution. Silent on manducatio impiorum. Eucharistic rite: Benka 2024, pp. 131–150.",
        },
        ba: {
          eyebrow: "Rukopis · ostrý register / Manuscript · sharp",
          title: "Bystrická agenda 1585",
          body: "Slovenský rukopisný doplnok pre lokálne použitie v baníckych mestách, napísaný o štyri roky neskôr. Výslovné luteránske manducatio impiorum; identifikatórna apozícia „Syna Božijho“. Tá istá teológia, ostrejšie hrany. Benka 2024, pp. 265–368.",
          bodyEn: "A Slovak manuscript supplement for local use in the mining towns, written four years later. Explicit Lutheran manducatio impiorum; the identificatory apposition “Syna Božijho”. The same theology, sharper edges. Benka 2024, pp. 265–368.",
        },
      };
      const cd = {
        eyebrow: $("codex-eyebrow"), title: $("codex-title"),
        body: $("codex-body"), bodyEn: $("codex-body-en"),
      };
      const strata = document.querySelectorAll(".codex-stratum");
      function selectStratum(key) {
        const c = codexCopy[key];
        if (!c) return;
        cd.eyebrow.textContent = c.eyebrow;
        cd.title.textContent = c.title;
        cd.body.textContent = c.body;
        cd.bodyEn.textContent = c.bodyEn;
        strata.forEach((g) => {
          const on = g.dataset.stratum === key;
          g.classList.toggle("is-active", on);
          g.classList.toggle("is-dim", !on);
        });
      }
      strata.forEach((g) => {
        g.addEventListener("click", () => selectStratum(g.dataset.stratum));
        g.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") { e.preventDefault(); selectStratum(g.dataset.stratum); }
        });
      });

      // ── Silence → broken ──
      const sbtn = $("silence-btn");
      const sreveal = $("silence-reveal");
      function openReveal() {
        sreveal.classList.add("is-open");
        sbtn.setAttribute("aria-expanded", "true");
        sbtn.style.display = "none";
      }
      if (sbtn && sreveal) {
        sbtn.addEventListener("click", openReveal);
        // auto-reveal once when scrolled into view
        if ("IntersectionObserver" in window) {
          const io = new IntersectionObserver((entries) => {
            entries.forEach((en) => {
              if (en.isIntersecting) { openReveal(); io.disconnect(); }
            });
          }, { threshold: 0.45 });
          io.observe(document.getElementById("silence-block"));
        }
      }
    })();
  </script>
