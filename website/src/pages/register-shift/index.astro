---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EpistemicLegend from "../../components/EpistemicLegend.astro";

const base = import.meta.env.BASE_URL;
const baseN = base.replace(/\/$/, "");
const baseHref = baseN.endsWith("/") ? baseN : baseN + "/";
const pageUrl = Astro.site
  ? new URL("register-shift/", new URL(baseHref, Astro.site)).toString()
  : `${baseN}/register-shift/`;

// ════════════════════════════════════════════════════════════════════
// REGISTER SHIFT — interactive flagship for the HE paper's central finding
// ────────────────────────────────────────────────────────────────────
// Thesis: the SAME Eucharistic doctrine is articulated at DIFFERENT
// registers — moderate → polemically sharp — across four documents and
// 61 years, with the Formula of Concord (1577) as the disciplinary
// threshold. Confessional sharpening is register work, visible at the
// granularity of a single bound codex (AC 1581 + BA 1585).
//
// `pos` is the register-intensity coordinate (0 = moderate, 100 = sharp).
// It is NOT a time axis: AC 1581 sits LEFT of the FC threshold even though
// FC (1577) predates it — the paper's point is precisely that AC keeps the
// moderate register despite FC, and BA adopts the sharpened one.
// ════════════════════════════════════════════════════════════════════

type Tone = "irenic" | "moderate" | "sharp";

interface Station {
  id: string;
  short: string;
  full: string;
  fullEn: string;
  year: number;
  pos: number; // 0..100 register-intensity coordinate
  tone: Tone;
  kindSk: string;
  kindEn: string;
  registerSk: string;
  registerEn: string;
  verbatim: string; // verbatim Czech/Slovak Eucharistic phrase
  verbatimEn: string;
  manducatio: boolean; // is manducatio impiorum explicit?
  manducatioClause?: string;
  manducatioClauseEn?: string;
  glossSk: string;
  glossEn: string;
  cite: string;
  link: { href: string; labelSk: string };
}

const stations: Station[] = [
  {
    id: "cb",
    short: "CB 1575",
    full: "Confessio Bohemica",
    fullEn: "Bohemian Confession",
    year: 1575,
    pos: 9,
    tone: "irenic",
    kindSk: "Medzikonfesionálny kompromis",
    kindEn: "Cross-confessional compromise",
    registerSk: "Irenický register „both/and“",
    registerEn: "Irenic both/and register",
    verbatim: "duchovně i podstatně, věrou i také ústy",
    verbatimEn: "spiritually and substantially, by faith and also by mouth",
    manducatio: false,
    glossSk:
      "Vyrokovaný konsenzus utrakvistov, luteránov a Jednoty bratskej. Eucharistický článok (čl. XV) drží luteránske aj reformované dôrazy v jednej formule — zámerne both/and, aby bol konfesionálne široko prijateľný. Mlčí o manducatio impiorum.",
    glossEn:
      "A negotiated consensus of Utraquists, Lutherans, and the Unity of Brethren. The Eucharistic article (Art. XV) holds both the Lutheran and the Reformed emphases in one formula — deliberately both/and, for the broadest confessional usability. Silent on manducatio impiorum.",
    cite: "Hrejsa 1912, čl. XV (pp. 695–717)",
    link: { href: "/cb1575/", labelSk: "CB 1575 archív" },
  },
  {
    id: "ac",
    short: "AC 1581",
    full: "Agenda Česká",
    fullEn: "Czech Agenda (printed)",
    year: 1581,
    pos: 31,
    tone: "moderate",
    kindSk: "Tlačená česko-luteránska agenda",
    kindEn: "Printed Czech-Lutheran agenda",
    registerSk: "Mierny český luteránsky register",
    registerEn: "Moderate Czech-Lutheran register",
    verbatim: "tělo a krev",
    verbatimEn: "body and blood — without “pravý” / “substanciálny”",
    manducatio: false,
    glossSk:
      "Identifikatórne „tělo a krev“ bez polemicky špecifikujúcich prívlastkov („pravý“, „substanciálny“). Hodné prijímanie kotví vo viere v slová ustanovenia. Nehodné prijímanie zostáva nevyslovené — registrová voľba, nie teologická reticencia.",
    glossEn:
      "Identificatory “tělo a krev” without the polemically specifying adjectives (“pravý”, “substanciálny”). Worthy reception is grounded in faith in the words of institution. Unworthy reception is left unspoken — a register choice, not theological reticence.",
    cite: "Benka 2024, p. 79; rite pp. 131–150",
    link: { href: "/diff/pair-006/", labelSk: "PAIR_006 diff" },
  },
  {
    id: "ba",
    short: "BA 1585",
    full: "Bystrická agenda",
    fullEn: "Bystrická agenda (manuscript)",
    year: 1585,
    pos: 74,
    tone: "sharp",
    kindSk: "Rukopisný slovenský doplnok",
    kindEn: "Manuscript Slovak supplement",
    registerSk: "Ostrejší hornouhorsko-luteránsky register",
    registerEn: "Sharper Upper-Hungarian Lutheran register",
    verbatim: "Tělo a Krew Syna Božijho",
    verbatimEn: "the Body and Blood of the Son of God",
    manducatio: true,
    manducatioClause: "hodným k spasenij — nehodným ne k spasenij, ale k zatraczenij wěčnemu",
    manducatioClauseEn:
      "to the worthy for salvation — to the unworthy not for salvation, but for eternal damnation",
    glossSk:
      "O štyri roky neskôr, v tom istom kódexe, BA prelomí mlčanie AC: výslovné luteránske manducatio impiorum. Tá istá teológia — ostrejšie hrany. Pridáva aj identifikatórnu apozíciu „Syna Božijho“.",
    glossEn:
      "Four years later, in the same codex, BA breaks AC's silence: explicit Lutheran manducatio impiorum. The same theology — sharper edges. It also adds the identificatory apposition “Syna Božijho”.",
    cite: "Benka 2024, pp. 78–79",
    link: { href: "/diff/pair-006/#manducatio_impiorum", labelSk: "PAIR_006 · manducatio" },
  },
  {
    id: "cs",
    short: "CS 1636",
    full: "Cithara Sanctorum",
    fullEn: "Cithara Sanctorum (printed hymnal)",
    year: 1636,
    pos: 93,
    tone: "sharp",
    kindSk: "Verejne tlačený luteránsky spevník",
    kindEn: "Publicly-printed Lutheran hymnal",
    registerSk: "Konsolidovaný slovenský luteránsky register",
    registerEn: "Consolidated Slovak-Lutheran register",
    verbatim: "Tranovského diferenciálna editorská ruka",
    verbatimEn: "Tranovský's differential editorial hand",
    manducatio: true,
    manducatioClause:
      "ostrenie v eucharistických, mariánskych a ekleziologických rubrikách",
    manducatioClauseEn:
      "sharpening in the Eucharistic, Marian, and ecclesiological rubrics",
    glossSk:
      "O pol storočia neskôr Tranovský preberá ~49 % staršieho repertoáru utrakvistického pôvodu a edituje konfesionálne citlivé rubriky smerom k luteránskej norme. Ten istý smer ostrenia — teraz vo verejnej tlači.",
    glossEn:
      "Half a century later Tranovský absorbs ~49% of older repertoire of Utraquist origin and edits confessionally sensitive rubrics toward the Lutheran norm. The same direction of sharpening — now in public print.",
    cite: "Grešová-Sekelská 2021; Vajda 1944",
    link: { href: "/trajectory/", labelSk: "Trajektória CB→CS" },
  },
];

// FC threshold position on the register axis (between AC and BA).
const FC_POS = 53;

// ── Twin-line chart geometry (server-rendered; JS adds the moving playhead) ──
const CHART = { w: 800, h: 250, x0: 64, x1: 760, yTop: 44, yBot: 206 };
const xForPos = (p: number) => CHART.x0 + (p / 100) * (CHART.x1 - CHART.x0);
// Register line: y descends (rises visually) with pos.
const yForReg = (p: number) => CHART.yBot - (p / 100) * (CHART.yBot - CHART.yTop);
const DOCTRINE_Y = CHART.yTop + 14; // flat, near the top (constant substance)
const regPolyline = stations.map((s) => `${xForPos(s.pos)},${yForReg(s.pos)}`).join(" ");
const fcX = xForPos(FC_POS);

const toneHex: Record<Tone, string> = {
  irenic: "#2E8B8B", // unity teal
  moderate: "#D4A843", // lutheran gold
  sharp: "#8B2332", // utraquist crimson / burgundy family
};

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ScholarlyArticle",
  name: "Register Shift — Confessional Sharpening as Register Work (CB 1575 · AC 1581 · BA 1585 · CS 1636)",
  alternateName:
    "Posun registra — konfesionálne ostrenie ako registrová práca",
  url: pageUrl,
  inLanguage: ["sk", "en"],
  isBasedOn:
    "Valčo, M. (2026). Intra-Codex Confessional Stratification in the Bratislava Lyceal Library Exemplar of Agenda Česká 1581 + Bystrická agenda 1585 (Historia Ecclesiastica, in submission).",
  publishingPrinciples:
    "Interactive visualisation of the paper's central finding. Verbatim AC/BA material from Benka 2024 (MLS X), cited at fair-use length. CC BY 4.0.",
  author: {
    "@type": "Person",
    name: "Michal Valčo",
    affiliation: { "@type": "Organization", name: "ETF UK Bratislava" },
  },
  isPartOf: {
    "@type": "ResearchProject",
    name: "TEPALIT (APVV-24-0484)",
    funder: {
      "@type": "Organization",
      name: "Slovak Research and Development Agency",
      identifier: "APVV-24-0484",
    },
  },
  keywords: [
    "register shift",
    "manducatio impiorum",
    "Agenda Česká 1581",
    "Bystrická agenda 1585",
    "Confessio Bohemica 1575",
    "Cithara Sanctorum 1636",
    "Formula of Concord",
    "lex orandi lex credendi",
    "confessionalisation",
    "intra-codex stratification",
  ],
};
---

<BaseLayout
  title="Register Shift — confessional sharpening you can scrub"
  description="Interactive flagship for the HE paper: the same Eucharistic doctrine articulated at rising registers — moderate to polemically sharp — across CB 1575, AC 1581, BA 1585, CS 1636, with the Formula of Concord 1577 as the threshold. Scrub the register, watch the manducatio impiorum break the silence."
  lang="sk"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />
  <!-- Data island: authoritative station data for the inline controller -->
  <script
    type="application/json"
    id="rs-data"
    set:html={JSON.stringify({ stations, fcPos: FC_POS, chart: CHART, doctrineY: DOCTRINE_Y, base: baseN })}
  />

  <!-- ═══════════ HERO ═══════════ -->
  <section class="relative overflow-hidden bg-ink-800 px-6 py-16 text-parchment md:py-20">
    <div
      class="absolute inset-0 opacity-40"
      style="background: radial-gradient(ellipse at 18% 40%, rgba(212,168,67,0.22) 0%, transparent 55%),
             radial-gradient(ellipse at 82% 60%, rgba(139,35,50,0.22) 0%, transparent 55%);"
      aria-hidden="true"
    ></div>
    <div class="relative mx-auto max-w-content">
      <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-gold">
        Lex orandi, lex credendi · Interaktívny nález / Interactive finding
      </p>
      <h1 class="mt-4 font-display text-3xl font-bold leading-tight text-parchment-100 md:text-5xl">
        Posun registra
      </h1>
      <p class="mt-3 font-display text-lg font-medium text-parchment-300 md:text-xl">
        Tá istá náuka, ostrejší jazyk — konfesionálne ostrenie ako práca s registrom
      </p>
      <h2 class="mt-5 font-display text-xl font-semibold text-parchment-200" lang="en">
        Register Shift
      </h2>
      <p class="mt-2 max-w-prose font-sans text-sm leading-relaxed text-parchment-400" lang="en">
        The same Eucharistic doctrine, articulated at a rising register — from
        moderate to polemically sharp — across four documents and 61 years. The
        sharpening is not a change of <em>substance</em> but of <em>shape</em>,
        and it becomes visible at the granularity of a single bound codex.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-2 font-mono text-[11px] text-parchment-400">
        <span class="rounded-full border border-parchment-300/20 px-3 py-1">CB 1575</span>
        <span aria-hidden="true">→</span>
        <span class="rounded-full border border-parchment-300/20 px-3 py-1">AC 1581</span>
        <span aria-hidden="true" class="text-gold">⟂ FC 1577</span>
        <span aria-hidden="true">→</span>
        <span class="rounded-full border border-parchment-300/20 px-3 py-1">BA 1585</span>
        <span aria-hidden="true">→</span>
        <span class="rounded-full border border-parchment-300/20 px-3 py-1">CS 1636</span>
      </div>
    </div>
  </section>

  <!-- ═══════════ THESIS CALLOUT ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-10">
    <blockquote class="blockquote-scholarly text-lg leading-relaxed">
      <p>
        Konfesionálne ostrenie nie je výlučne fenoménom <em>medzikonfesionálneho
        prenosu</em>. Je to aj fenomén <strong>registrovej intenzifikácie</strong>,
        pozorovateľný na úrovni jediného fyzického kódexu, ktorý pôvodní
        používatelia zviazali ako jednu liturgickú jednotku.
      </p>
      <p class="mt-3 font-sans text-sm not-italic text-ink-300" lang="en">
        Confessional sharpening is not only a phenomenon of cross-confessional
        transfer. It is also a phenomenon of <strong>register intensification</strong>,
        observable at the granularity of a single physical codex bound together
        by its early users.
      </p>
    </blockquote>
  </section>

  <!-- ═══════════ ① THE SCRUBBER (signature interactive) ═══════════ -->
  <section class="mx-auto max-w-wide px-6 py-12">
    <h2 class="text-section-title text-ink">① Potiahnite register</h2>
    <p class="mt-1 font-sans text-sm italic text-ink-300" lang="en">
      Scrub the register — drag from moderate to sharp and watch the words change
    </p>

    <div class="mt-8 rounded-xl border border-parchment-400/50 bg-parchment-50 p-5 shadow-sm md:p-8">
      <!-- Track + handle -->
      <div class="rs-track-wrap">
        <div class="flex items-center justify-between font-sans text-[11px] font-semibold uppercase tracking-wider">
          <span class="text-lutheran-dark">◀ Mierny / Moderate</span>
          <span class="text-burgundy">Ostrý / Sharp ▶</span>
        </div>

        <div class="rs-track relative mt-3">
          <!-- gradient rail -->
          <div class="rs-rail" aria-hidden="true"></div>
          <!-- FC threshold marker -->
          <div class="rs-fc" id="rs-fc" style={`left:${FC_POS}%`} aria-hidden="true">
            <span class="rs-fc-line"></span>
            <span class="rs-fc-label">FC 1577</span>
          </div>
          <!-- station ticks -->
          {stations.map((s) => (
            <button
              type="button"
              class="rs-tick"
              data-pos={s.pos}
              style={`left:${s.pos}%`}
              aria-label={`${s.short} — ${s.registerEn}`}
              title={`${s.short}`}
            >
              <span class="rs-tick-dot" style={`--tone:${toneHex[s.tone]}`}></span>
              <span class="rs-tick-label">{s.short}</span>
            </button>
          ))}
          <!-- the actual range input (keyboard + touch accessible) -->
          <input
            id="rs-range"
            class="rs-range"
            type="range"
            min="0"
            max="100"
            value="31"
            step="1"
            aria-label="Register intensity from moderate to sharp"
          />
        </div>
      </div>

      <!-- Reading panel + meter -->
      <div class="mt-10 grid gap-6 lg:grid-cols-[1.3fr_1fr]">
        <!-- Active document reading -->
        <article id="rs-panel" class="rounded-lg border-l-4 p-5" style="border-color:#D4A843;background:rgba(212,168,67,0.06)">
          <div class="flex flex-wrap items-baseline justify-between gap-2">
            <div>
              <p class="font-mono text-[11px] tracking-wider text-ink-300">
                <span id="rs-year">1581</span> · <span id="rs-kind">Printed Czech-Lutheran agenda</span>
              </p>
              <h3 class="mt-0.5 font-display text-2xl font-bold text-ink" id="rs-short">AC 1581</h3>
              <p class="font-display text-sm font-medium text-ink-400" id="rs-full">Agenda Česká</p>
            </div>
            <span id="rs-register" class="rounded-full bg-parchment-200/70 px-3 py-1 font-sans text-[11px] font-semibold text-ink-400">
              Mierny český luteránsky register
            </span>
          </div>

          <p class="mt-5 font-sans text-[10px] font-semibold uppercase tracking-wider text-ink-300">
            Eucharistická formula / Eucharistic articulation
          </p>
          <blockquote class="mt-1.5 border-l-2 border-ink-300/30 pl-3">
            <p class="font-serif text-xl italic leading-snug text-ink" lang="cs" id="rs-verbatim">tělo a krev</p>
            <p class="mt-1 font-sans text-xs italic text-ink-300" lang="en" id="rs-verbatim-en">body and blood</p>
          </blockquote>

          <!-- manducatio impiorum status -->
          <div class="mt-5 rounded-md p-3 transition-colors duration-500" id="rs-mand-box" style="background:rgba(0,0,0,0.03)">
            <p class="font-sans text-[10px] font-semibold uppercase tracking-wider text-ink-300">
              Manducatio impiorum
            </p>
            <p class="mt-1 font-sans text-sm font-semibold" id="rs-mand-status">— mlčanie (zámerné) / deliberate silence</p>
            <p class="mt-1 font-serif text-sm italic leading-snug text-burgundy opacity-0 transition-opacity duration-700" lang="cs" id="rs-mand-clause"></p>
            <p class="mt-0.5 font-sans text-xs italic text-ink-300 opacity-0 transition-opacity duration-700" lang="en" id="rs-mand-clause-en"></p>
          </div>

          <p class="mt-4 font-serif text-sm leading-relaxed text-ink-400" id="rs-gloss">Identifikatórne „tělo a krev“ bez polemicky špecifikujúcich prívlastkov („pravý“, „substanciálny“). Hodné prijímanie kotví vo viere v slová ustanovenia. Nehodné prijímanie zostáva nevyslovené — registrová voľba, nie teologická reticencia.</p>
          <p class="mt-2 font-sans text-xs italic leading-relaxed text-ink-300" lang="en" id="rs-gloss-en">Identificatory “tělo a krev” without the polemically specifying adjectives. Worthy reception is grounded in faith in the words of institution; unworthy reception is left unspoken — a register choice.</p>

          <div class="mt-4 flex flex-wrap items-center justify-between gap-2 border-t border-parchment-300/50 pt-3">
            <span class="font-mono text-[10px] text-ink-300" id="rs-cite">Benka 2024, p. 79; rite pp. 131–150</span>
            <a id="rs-link" href={`${baseN}/diff/pair-006/`} class="font-sans text-[11px] font-semibold text-burgundy no-underline hover:underline">PAIR_006 diff →</a>
          </div>
        </article>

        <!-- Meter + twin-line chart -->
        <div class="flex flex-col gap-6">
          <!-- sharpness meter -->
          <div>
            <div class="flex items-baseline justify-between">
              <p class="font-sans text-[10px] font-semibold uppercase tracking-wider text-ink-300">
                Polemická ostrosť / Polemical sharpness
              </p>
              <span class="font-mono text-sm font-bold text-ink" id="rs-meter-pct">31%</span>
            </div>
            <div class="mt-2 h-3 overflow-hidden rounded-full bg-parchment-300/60">
              <div id="rs-meter" class="h-full rounded-full transition-[width] duration-200" style="width:31%;background:linear-gradient(90deg,#D4A843,#B5344A,#8B2332)"></div>
            </div>
          </div>

          <!-- twin-line chart: doctrine flat vs register rising -->
          <div class="rounded-lg border border-parchment-300/60 bg-parchment-100/40 p-3">
            <p class="font-sans text-[10px] font-semibold uppercase tracking-wider text-ink-300">
              Náuka vs. register / Doctrine vs. register
            </p>
            <svg
              viewBox={`0 0 ${CHART.w} ${CHART.h}`}
              class="mt-1 w-full"
              role="img"
              aria-label="Twin-line chart: doctrine stays flat while register rises across CB, AC, BA, CS"
            >
              <!-- doctrine line (flat, constant substance) -->
              <line
                x1={CHART.x0}
                y1={DOCTRINE_Y}
                x2={CHART.x1}
                y2={DOCTRINE_Y}
                stroke="#504A3F"
                stroke-width="2.5"
                stroke-dasharray="2 4"
              />
              <text x={CHART.x0} y={DOCTRINE_Y - 8} font-family="ui-sans-serif,system-ui" font-size="12" font-weight="600" fill="#504A3F">
                Náuka — tá istá podstata / Doctrine — same substance
              </text>

              <!-- register polyline (rising shape) -->
              <polyline
                points={regPolyline}
                fill="none"
                stroke="#8B2332"
                stroke-width="3"
                stroke-linejoin="round"
                stroke-linecap="round"
              />

              <!-- FC threshold -->
              <line x1={fcX} y1={CHART.yTop - 6} x2={fcX} y2={CHART.yBot + 6} stroke="#A68230" stroke-width="1.2" stroke-dasharray="4 3" />
              <text x={fcX} y={CHART.yBot + 22} font-family="ui-monospace,monospace" font-size="11" text-anchor="middle" fill="#A68230">FC 1577</text>

              <!-- station dots + labels -->
              {stations.map((s) => (
                <g>
                  <circle cx={xForPos(s.pos)} cy={yForReg(s.pos)} r="5" fill={toneHex[s.tone]} />
                  <text
                    x={xForPos(s.pos)}
                    y={yForReg(s.pos) - 12}
                    font-family="ui-sans-serif,system-ui"
                    font-size="11"
                    font-weight="700"
                    text-anchor="middle"
                    fill="#1A1611"
                  >{s.short}</text>
                </g>
              ))}

              <!-- moving playhead (JS-driven) -->
              <line id="rs-playhead" x1={xForPos(31)} y1={CHART.yTop - 6} x2={xForPos(31)} y2={CHART.yBot + 6} stroke="#1A1611" stroke-width="1.5" opacity="0.5" />
              <circle id="rs-playdot" cx={xForPos(31)} cy={yForReg(31)} r="7" fill="#1A1611" stroke="#F5F0E8" stroke-width="2" />

              <!-- register axis label -->
              <text x={CHART.x0} y={CHART.h - 6} font-family="ui-sans-serif,system-ui" font-size="11" fill="#7C7367">register: mierny → ostrý / moderate → sharp</text>
            </svg>
          </div>
        </div>
      </div>

      <p class="mt-6 text-center font-sans text-xs text-ink-300">
        <span class="rs-hint">Potiahnite jazdec alebo kliknite na medzník · klávesnica: ←/→ ·
        <span lang="en">drag the slider or click a milestone · keyboard ←/→</span></span>
      </p>
    </div>

    <div class="mt-6">
      <EpistemicLegend compact={true} />
    </div>
  </section>

  <div class="ornament-rule"></div>

  <!-- ═══════════ ② THE BOUND CODEX ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-12">
    <h2 class="text-section-title text-ink">② Jeden kódex, dva registre</h2>
    <p class="mt-1 font-sans text-sm italic text-ink-300" lang="en">
      One physical codex, two registers — intra-codex stratification
    </p>
    <p class="mt-4 max-w-prose font-serif text-sm leading-relaxed text-ink-400">
      Bratislavský exemplár Lyceálnej knižnice (dnes Ústredná knižnica SAV) viaže
      tlačenú <em>Agendu Českú</em> 1581 a rukopisnú <em>Bystrickú agendu</em> 1585
      do jedného fyzického zväzku. Pôvodní používatelia ich zviazali ako jednu
      liturgickú jednotku — a práve preto je posun registra čitateľný na úrovni
      jedného predmetu. Kliknite na vrstvu.
    </p>

