---
import BaseLayout from "../../layouts/BaseLayout.astro";
import EpistemicLegend from "../../components/EpistemicLegend.astro";
import TraditionBadge from "../../components/TraditionBadge.astro";
import {
  getHymnPairs,
  getEvidenceById,
  getLocusByCode,
  TRANSFER_DIRECTION_LABELS,
  EVIDENTIARY_LABELS,
  VERIFICATION_LABELS,
  type HymnPair,
  type HymnicEvidence,
} from "../../data/taxonomy";

const pairs = getHymnPairs();
const base = import.meta.env.BASE_URL;
// Normalised base (no trailing slash) for safe path concatenation regardless
// of whether import.meta.env.BASE_URL ends with /. Use baseN + "/path" idiom.
const baseN = base.replace(/\/$/, "");
// Build absolute URLs from Astro.site (set in astro.config.mjs) for env-aware
// canonical/JSON-LD/citation links. new URL() guarantees no double slashes.
const baseHref = baseN.endsWith("/") ? baseN : baseN + "/";
const dossierUrl = Astro.site
  ? new URL("hymn-pairs/", new URL(baseHref, Astro.site)).toString()
  : `${baseN}/hymn-pairs/`;
const pairPermalink = (pairId: string) => `${dossierUrl}#${pairId}`;

const epistemicClasses: Record<string, string> = {
  FACTUAL: "epistemic-factual",
  INTERPRETIVE: "epistemic-interpretive",
  DEFERRED: "epistemic-deferred",
};

const epistemicLabels: Record<string, { sk: string; en: string }> = {
  FACTUAL: { sk: "Doložené tvrdenie", en: "Factual claim" },
  INTERPRETIVE: { sk: "Odborná interpretácia", en: "Scholarly interpretation" },
  DEFERRED: { sk: "Otvorená otázka", en: "Open question" },
};

const evidentiaryRing: Record<string, string> = {
  DOCUMENTED: "ring-2 ring-epistemic-factual/40",
  INFERRED: "ring-2 ring-epistemic-interpretive/40",
  // Tailwind has no ring-dashed utility; use a dashed border for CONJECTURED.
  CONJECTURED: "border-2 border-dashed border-epistemic-deferred/60",
};

const verificationBadge: Record<string, string> = {
  VERIFIED: "bg-epistemic-factual/15 text-epistemic-factual",
  SECONDARY_ONLY: "bg-epistemic-interpretive/15 text-epistemic-interpretive",
  PRIMARY_PENDING: "bg-gold/15 text-gold-dark",
  UNVERIFIED: "bg-burgundy/10 text-burgundy",
};

interface PairView {
  pair: HymnPair;
  source?: HymnicEvidence;
  receptor?: HymnicEvidence;
  primaryLocusName: string;
  primaryLocusEn: string;
  citationIds: string[];
  modificationTypes: string[];
  bibtex: string;
  apa: string;
  permalink: string;
  mode: ModeCode;
}

// ── Four-Modes-of-Lutheranisation framing (per Theologos paper §§5–6) ──
// The chapter's substantive scholarly move (the cross-confessional vs
// intra-Lutheran distinction) is operationalised on this page as four
// equal-weighted classification modes across the 16th–18th c. corpus.
// Cross-confessional + intra-Lutheran-intensification are the two "novel"
// modes from the Theologos paper; regional-continuity and research-target
// are auxiliary categories that complete the schema. Mode is derived from
// `transfer_direction` plus the trust-state for non-directional/research-target
// placement. Slovak labels confirmed by Michal 2026-05-09.
type ModeCode =
  | "CROSS_CONFESSIONAL"
  | "INTRA_LUTHERAN_INTENSIFICATION"
  | "REGIONAL_LUTHERAN_CONTINUITY"
  | "RESEARCH_TARGET";

const MODE_ORDER: ModeCode[] = [
  "CROSS_CONFESSIONAL",
  "INTRA_LUTHERAN_INTENSIFICATION",
  "REGIONAL_LUTHERAN_CONTINUITY",
  "RESEARCH_TARGET",
];

const MODE_LABELS: Record<ModeCode, { sk: string; en: string }> = {
  CROSS_CONFESSIONAL: {
    sk: "Medzi-konfesionálna luteranizácia",
    en: "Cross-confessional Lutheranisation",
  },
  INTRA_LUTHERAN_INTENSIFICATION: {
    sk: "Intra-luteránska intenzifikácia registra",
    en: "Intra-Lutheran register intensification",
  },
  REGIONAL_LUTHERAN_CONTINUITY: {
    sk: "Regionálna luteránska kontinuita",
    en: "Regional Lutheran continuity",
  },
  RESEARCH_TARGET: {
    sk: "Výskumné ciele",
    en: "Research targets",
  },
};

const MODE_DESCRIPTIONS: Record<ModeCode, { sk: string; en: string }> = {
  CROSS_CONFESSIONAL: {
    sk: "Klasický príbeh: Tranovský pri preberaní materiálu z bratrských a utrakvistických prameňov vedome ostril ich teológiu na augsburský luteránsky štandard. Editorský zásah na hranici dvoch konfesií.",
    en: "The classical account: in absorbing material from Brethren and Utraquist sources, Tranovský deliberately sharpened its theology to the Augsburg-Lutheran standard. Editorial intervention at the cross-confessional boundary.",
  },
  INTRA_LUTHERAN_INTENSIFICATION: {
    sk: "Komplementárne zistenie zo štúdie Theologos (PAIR_006): konfesionálne ostrenie prebieha aj vnútri luteránskeho prostredia — od mierneho českého tlačeného registra (AC 1581) k tvrdšiemu slovenskému rukopisnému registru (BA 1585), zviazaných v jednom exemplári Lyceálnej knižnice.",
    en: "A complementary finding from the Theologos paper (PAIR_006): confessional sharpening also operates within the Lutheran orbit itself — from a moderate Czech printed register (AC 1581) to a sharper Slovak manuscript register (BA 1585), bound together in one Lyceal Library exemplar.",
  },
  REGIONAL_LUTHERAN_CONTINUITY: {
    sk: "Kontinuálny prenos: hungarsko-luteránska liturgická prax baníckych miest sa premietla do Cithary Sanctorum prostredníctvom konkrétnych textovo-melodických jednotiek, bez doložiteľnej teologickej úpravy.",
    en: "Continuous transmission: Hungarian-Lutheran liturgical practice of the mining towns flowed into the Cithara Sanctorum through concrete text-and-melody units, without documented theological modification.",
  },
  RESEARCH_TARGET: {
    sk: "Pracovné hypotézy, otvorené otázky a nesmerové porovnania. Páry s neoverenou bázou, neúplnou kolaciou alebo bez doloženého smeru prenosu — transparentne označené ako výskumné ciele, nie ako dôkaz.",
    en: "Working hypotheses, open questions, and non-directional comparisons. Pairs with unverified bases, incomplete collation, or no documented transfer direction — transparently flagged as research targets, not as evidence.",
  },
};

function deriveMode(pair: HymnPair): ModeCode {
  if (pair.transfer_direction === "LUTHERAN_CONFESSIONAL_INTENSIFICATION") {
    return "INTRA_LUTHERAN_INTENSIFICATION";
  }
  if (pair.transfer_direction === "LUTHERAN_REGIONAL_CONTINUITY") {
    return "REGIONAL_LUTHERAN_CONTINUITY";
  }
  // Empty `transfer_direction` is, per `taxonomy/SCHEMA.md`, the field's value
  // for "non-directional comparisons" (any trust-state, not only DEFERRED
  // research-target manifests). All such rows belong in the RESEARCH_TARGET
  // group on the page — both the current PAIR_003 manifest and any hypothetical
  // future non-directional FACTUAL/INTERPRETIVE pair, which by virtue of
  // lacking a transfer claim is a candidate for further work rather than a
  // worked example of any of the three directional modes. The mode-group
  // description for RESEARCH_TARGET covers both cases ("working hypotheses
  // and open questions" / "non-directional pairs").
  // Note: PAIR_002 is a working hypothesis WITH UNITY_TO_LUTHERAN direction;
  // per the strategy doc §A3 it is grouped with cross-confessional (its
  // directional axis), with the existing "Research target — verification in
  // progress" banner on the card itself flagging its trust-state honestly.
  if (!pair.transfer_direction) {
    return "RESEARCH_TARGET";
  }
  return "CROSS_CONFESSIONAL";
}

const isPlaceholderText = (s: string) =>
  /^\[.*pending|^\[text to be filled/i.test(s.trim());

const buildBibtex = (p: HymnPair): string =>
  `@misc{TEPALIT_${p.pair_id},\n  title        = {{${p.pair_label_en}}},\n  author       = {Val\\v{c}o, Michal and TEPALIT Project},\n  year         = {2026},\n  note         = {Hymn-pair dossier ${p.pair_id}, epistemic status: ${p.epistemic_status}},\n  howpublished = {APVV-24-0484 (TEPALIT) digital companion},\n  url          = {${pairPermalink(p.pair_id)}}\n}`;

const buildApa = (p: HymnPair): string =>
  `Valčo, M., & TEPALIT Project. (2026). ${p.pair_label_en} [Hymn-pair dossier ${p.pair_id}]. APVV-24-0484 (TEPALIT) Digital Companion. ${pairPermalink(p.pair_id)}`;

const pairViews: PairView[] = pairs.map((pair) => {
  const source = getEvidenceById(pair.source_text_id);
  const receptor = getEvidenceById(pair.receptor_text_id);
  const locus = getLocusByCode(pair.primary_locus_code);
  return {
    pair,
    source,
    receptor,
    primaryLocusName: locus
      ? `${locus.locus_code} · ${locus.locus_name_sk}`
      : pair.primary_locus_code,
    primaryLocusEn: locus ? locus.locus_name_en : "",
    citationIds: pair.citation_chain
      ? pair.citation_chain.split(";").map((s) => s.trim()).filter(Boolean)
      : [],
    modificationTypes: pair.modification_typology
      ? pair.modification_typology
          .split(";")
          .map((s) => s.trim())
          .filter(Boolean)
      : [],
    bibtex: buildBibtex(pair),
    apa: buildApa(pair),
    permalink: pairPermalink(pair.pair_id),
    mode: deriveMode(pair),
  };
});

// Two-axis sort: mode first (per MODE_ORDER), then epistemic status within mode.
// This produces the strategy-doc grouping while preserving FACTUAL → INTERPRETIVE
// → DEFERRED secondary ordering inside each mode.
const epistemicOrder: Record<string, number> = {
  FACTUAL: 0,
  INTERPRETIVE: 1,
  DEFERRED: 2,
};
const modeIndex: Record<ModeCode, number> = MODE_ORDER.reduce(
  (acc, m, i) => {
    acc[m] = i;
    return acc;
  },
  {} as Record<ModeCode, number>,
);
pairViews.sort((a, b) => {
  const modeDelta = modeIndex[a.mode] - modeIndex[b.mode];
  if (modeDelta !== 0) return modeDelta;
  return (
    epistemicOrder[a.pair.epistemic_status] -
    epistemicOrder[b.pair.epistemic_status]
  );
});

// Group views by mode for render-time section headers. Maintains MODE_ORDER
// even when a mode has zero pairs (we skip empty groups in the render below).
const pairsByMode: Record<ModeCode, PairView[]> = {
  CROSS_CONFESSIONAL: [],
  INTRA_LUTHERAN_INTENSIFICATION: [],
  REGIONAL_LUTHERAN_CONTINUITY: [],
  RESEARCH_TARGET: [],
};
for (const v of pairViews) {
  pairsByMode[v.mode].push(v);
}

const counts = {
  total: pairs.length,
  factual: pairs.filter((p) => p.epistemic_status === "FACTUAL").length,
  interpretive: pairs.filter((p) => p.epistemic_status === "INTERPRETIVE")
    .length,
  deferred: pairs.filter((p) => p.epistemic_status === "DEFERRED").length,
  documented: pairs.filter((p) => p.evidentiary_strength === "DOCUMENTED")
    .length,
  verified: pairs.filter((p) => p.verification_status === "VERIFIED").length,
};

// JSON-LD: emit a Dataset record describing the dossier as a citable scholarly resource
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "TEPALIT Hymn-Pair Dossier",
  alternateName: "Hymno-páry — dôkazové dossier",
  description:
    "Case-study evidence layer for the Lutheranisation thesis: comparative dossiers per hymn pair with three orthogonal trust axes (epistemic, evidentiary, verification).",
  url: dossierUrl,
  identifier: [
    "https://doi.org/10.5281/zenodo.20081435",
    {
      "@type": "PropertyValue",
      propertyID: "DOI",
      value: "10.5281/zenodo.20081435",
    },
  ],
  sameAs: "https://doi.org/10.5281/zenodo.20081435",
  isPartOf: {
    "@type": "ResearchProject",
    name: "TEPALIT (APVV-24-0484)",
    funder: {
      "@type": "Organization",
      name: "Slovak Research and Development Agency",
      identifier: "APVV-24-0484",
    },
  },
  creator: {
    "@type": "Person",
    name: "Michal Valčo",
    affiliation: { "@type": "Organization", name: "ETF UK Bratislava" },
  },
  keywords: [
    "Reformation hymnology",
    "Cithara Sanctorum",
    "Lutheranisation",
    "Tranovský",
    "Czech Reformation",
    "Unity of Brethren",
    "Utraquism",
    "lex orandi lex credendi",
  ],
  license: "https://creativecommons.org/licenses/by/4.0/",
  hasPart: pairViews.map((v) => ({
    "@type": "CreativeWork",
    "@id": pairPermalink(v.pair.pair_id),
    name: v.pair.pair_label_en,
    description: v.pair.theological_argument_en.slice(0, 280),
    additionalType: "ScholarlyArticle",
    inLanguage: ["sk", "en"],
  })),
};
---

<BaseLayout
  title="Hymno-páry — dôkazové dossier"
  description="Hymn-pair dossier: case-study evidence layer for the Lutheranisation thesis. Each pair is an analytical record with epistemic flags, citation chain, and verification status."
  lang="sk"
>
  <!-- JSON-LD structured data for Scholar / search indexing -->
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />

  <!-- ═══════════ HEADER ═══════════ -->
  <section class="bg-ink-800 px-6 py-16 text-parchment">
    <div class="mx-auto max-w-content text-center">
      <p class="font-sans text-xs font-medium uppercase tracking-[0.2em] text-gold">
        Lex orandi, lex credendi · Hymn-Pair Dossier
      </p>
      <h1 class="mt-3 text-section-title font-display font-bold text-parchment-100">
        Hymno-páry
      </h1>
      <p class="mx-auto mt-2 max-w-prose font-sans text-sm uppercase tracking-wider text-parchment-500" lang="en">
        Hymn-Pair Dossier
      </p>
      <p class="mx-auto mt-6 max-w-prose text-parchment-400">
        Empirické jadro tézy o luteranizácii. Každý záznam je samostatný
        výskumný dossier — porovnávaný pár s argumentom, citačným reťazcom
        a tromi nezávislými osami dôvery: epistemický status, sila dôkazu
        a stav vlastnej verifikácie.
      </p>
      <p class="mx-auto mt-3 max-w-prose font-sans text-sm italic text-parchment-500" lang="en">
        The empirical core of the Lutheranisation thesis. Each record is a
        self-contained research dossier — a paired comparison with prose argument,
        citation chain, and three independent trust axes: epistemic status,
        evidentiary strength, and the project's own verification status.
      </p>
    </div>
  </section>

  <!-- ═══════════ SUMMARY STATS ═══════════ -->
  <div class="mx-auto max-w-wide px-6 pt-8">
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-5">
      <div class="card text-center">
        <p class="font-display text-3xl font-bold text-ink">{counts.total}</p>
        <p class="mt-1 font-sans text-xs text-ink-400">
          Spolu / <span lang="en">Total</span>
        </p>
      </div>
      <div class="card text-center epistemic-factual">
        <p class="font-display text-3xl font-bold text-ink">{counts.factual}</p>
        <p class="mt-1 font-sans text-xs text-ink-400">
          Doložené / <span lang="en">Factual</span>
        </p>
      </div>
      <div class="card text-center epistemic-interpretive">
        <p class="font-display text-3xl font-bold text-ink">
          {counts.interpretive}
        </p>
        <p class="mt-1 font-sans text-xs text-ink-400">
          Interpret. / <span lang="en">Interpretive</span>
        </p>
      </div>
      <div class="card text-center epistemic-deferred">
        <p class="font-display text-3xl font-bold text-ink">
          {counts.deferred}
        </p>
        <p class="mt-1 font-sans text-xs text-ink-400">
          Otvorené / <span lang="en">Deferred</span>
        </p>
      </div>
      <div class="card text-center">
        <p class="font-display text-3xl font-bold text-burgundy">
          {counts.verified}
        </p>
        <p class="mt-1 font-sans text-xs text-ink-400">
          Vlastná verif. / <span lang="en">Verified</span>
        </p>
      </div>
    </div>
  </div>

  <!-- ═══════════ TRUST AXES LEGEND ═══════════ -->
  <div class="mx-auto max-w-wide px-6 pt-6">
    <div class="rounded-lg bg-parchment-100/60 p-4">
      <h2 class="mb-3 font-sans text-xs font-semibold uppercase tracking-wider text-ink-400">
        Tri osi dôvery / <span lang="en">Three trust axes</span>
      </h2>
      <div class="grid gap-4 md:grid-cols-3">
        <div>
          <h3 class="font-sans text-sm font-semibold text-ink">
            1. Epistemický status
          </h3>
          <p class="mt-0.5 font-sans text-[11px] italic text-ink-300" lang="en">
            Type of claim
          </p>
          <p class="mt-2 text-xs text-ink-400">
            <strong>Factual</strong> · overiteľné /
            <strong>Interpretive</strong> · odborný úsudok /
            <strong>Deferred</strong> · vyžaduje expertné posúdenie
          </p>
        </div>
        <div>
          <h3 class="font-sans text-sm font-semibold text-ink">
            2. Sila textového dôkazu
          </h3>
          <p class="mt-0.5 font-sans text-[11px] italic text-ink-300" lang="en">
            Quality of textual evidence
          </p>
          <p class="mt-2 text-xs text-ink-400">
            <strong>Documented</strong> · v recenz. literatúre /
            <strong>Inferred</strong> · vlastná analýza textov /
            <strong>Conjectured</strong> · pracovná hypotéza
          </p>
        </div>
        <div>
          <h3 class="font-sans text-sm font-semibold text-ink">
            3. Stav vlastnej verifikácie
          </h3>
          <p class="mt-0.5 font-sans text-[11px] italic text-ink-300" lang="en">
            Project's own collation
          </p>
          <p class="mt-2 text-xs text-ink-400">
            <strong>Verified</strong> · skolacionované /
            <strong>Secondary only</strong> · iba podľa lit. /
            <strong>Primary pending</strong> · prístupné, kolacia čaká /
            <strong>Unverified</strong> · žiadny prístup
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════ FOUR-MODES CONCEPTUAL PRELUDE ═══════════ -->
  <div class="mx-auto max-w-wide px-6 pt-8">
    <div class="rounded-lg border-l-4 border-burgundy/60 bg-parchment-100/40 p-5">
      <h2 class="font-display text-base font-semibold text-ink">
        Štyri spôsoby luteranizácie
      </h2>
      <p class="mt-0.5 font-sans text-xs italic text-ink-300" lang="en">
        Four operational modes of Lutheranisation
      </p>
      <p class="mt-3 text-sm leading-relaxed text-ink-400">
        V štúdii pripravenej pre časopis <em>Theologos</em> rozlišujeme štyri
        operačné režimy konfesionálneho ostrenia v korpuse hymnov a liturgických
        prameňov 16.–18. storočia. Klasický príbeh <em>Cithary Sanctorum</em> 1636
        ako kompilácie z bratrských a utrakvistických zdrojov, ktoré Tranovský
        editorsky adaptoval, je <strong>medzi-konfesionálna luteranizácia</strong>.
        Komplementárne zistenie Theologos štúdie (PAIR_006) je
        <strong>intra-luteránska intenzifikácia registra</strong> — to isté
        ostrenie prebieha aj vnútri jedného luteránsky orientovaného kódexu, od
        miernej českej tlačenej Agendy Českej (1581) k tvrdšej slovenskej
        rukopisnej Bystrickej agende (1585). Tretí režim,
        <strong>regionálna luteránska kontinuita</strong>, sleduje priame
        textovo-melodické prevzatia z hungarsko-luteránskej liturgickej praxe
        baníckych miest do CS. Štvrtá kategória, <strong>výskumné ciele</strong>,
        zhromažďuje pracovné hypotézy a otvorené otázky transparentne označené
        ako neoverené.
      </p>
      <p class="mt-3 font-sans text-xs italic leading-relaxed text-ink-300" lang="en">
        The Theologos paper distinguishes four operational modes of confessional
        sharpening across the 16th–18th century hymnal and liturgical corpus.
        The classical account of <em>Cithara Sanctorum</em> 1636 as a compilation
        from Brethren and Utraquist sources adapted by Tranovský is
        <strong>cross-confessional Lutheranisation</strong>. The Theologos paper's
        complementary finding (PAIR_006) is <strong>intra-Lutheran register
        intensification</strong> — the same sharpening operating within a single
        Lutheran-aligned codex, from a moderate Czech printed <em>Agenda Česká</em>
        (1581) to a sharper Slovak manuscript <em>Bystrická agenda</em> (1585).
        A third mode, <strong>regional Lutheran continuity</strong>, traces direct
        text-and-melody continuities from Hungarian-Lutheran liturgical practice
        of the mining towns into CS. The fourth category,
        <strong>research targets</strong>, collects working hypotheses and open
        questions transparently flagged as unverified.
      </p>
    </div>
  </div>

  <!-- ═══════════ FILTER BAR ═══════════ -->
  <div class="mx-auto max-w-wide px-6 pt-6">
    <div class="rounded-lg border border-parchment-300/60 bg-parchment-50 p-4">
      <div class="flex flex-wrap items-center gap-3">
        <span class="font-sans text-xs font-semibold uppercase tracking-wider text-ink-400">
          Filter:
        </span>
        <label class="flex items-center gap-1.5 text-xs">
          <span class="text-ink-400">Režim</span>
          <select
            id="filter-mode"
            class="rounded border border-parchment-300 bg-parchment-50 px-2 py-1 font-sans text-xs"
          >
            <option value="">Všetky / All</option>
            {MODE_ORDER.map((m) => (
              <option value={m}>{MODE_LABELS[m].sk}</option>
            ))}
          </select>
        </label>
        <label class="flex items-center gap-1.5 text-xs">
          <span class="text-ink-400">Epistemika</span>
          <select
            id="filter-epistemic"
            class="rounded border border-parchment-300 bg-parchment-50 px-2 py-1 font-sans text-xs"
          >
            <option value="">Všetky / All</option>
            <option value="FACTUAL">Factual</option>
            <option value="INTERPRETIVE">Interpretive</option>
            <option value="DEFERRED">Deferred</option>
          </select>
        </label>
        <label class="flex items-center gap-1.5 text-xs">
          <span class="text-ink-400">Sila dôkazu</span>
          <select
            id="filter-evidentiary"
            class="rounded border border-parchment-300 bg-parchment-50 px-2 py-1 font-sans text-xs"
          >
            <option value="">Všetky / All</option>
            <option value="DOCUMENTED">Documented</option>
            <option value="INFERRED">Inferred</option>
            <option value="CONJECTURED">Conjectured</option>
          </select>
        </label>
        <label class="flex items-center gap-1.5 text-xs">
          <span class="text-ink-400">Verifikácia</span>
          <select
            id="filter-verification"
            class="rounded border border-parchment-300 bg-parchment-50 px-2 py-1 font-sans text-xs"
          >
            <option value="">Všetky / All</option>
            <option value="VERIFIED">Verified</option>
            <option value="SECONDARY_ONLY">Secondary only</option>
            <option value="PRIMARY_PENDING">Primary pending</option>
            <option value="UNVERIFIED">Unverified</option>
          </select>
        </label>
        <label class="flex items-center gap-1.5 text-xs">
          <span class="text-ink-400">Smer prenosu</span>
          <select
            id="filter-direction"
            class="rounded border border-parchment-300 bg-parchment-50 px-2 py-1 font-sans text-xs"
          >
            <option value="">Všetky / All</option>
            <option value="UTRAQUIST_TO_LUTHERAN">Utraquist → Lutheran</option>
            <option value="UNITY_TO_LUTHERAN">Unity → Lutheran</option>
            <option value="HUSSITE_TO_LUTHERAN">Hussite → Lutheran</option>
            <option value="LUTHERAN_REGIONAL_CONTINUITY">Regional Lutheran continuity</option>
            <option value="LUTHERAN_CONFESSIONAL_INTENSIFICATION">Lutheran confessional intensification</option>
            <option value="LATIN_TO_VERNACULAR">Latin → vernacular</option>
            <option value="GERMAN_TO_CZECH">German → Czech</option>
          </select>
        </label>
        <button
          id="filter-reset"
          type="button"
          class="ml-auto rounded-md bg-parchment-300/50 px-3 py-1 font-sans text-xs text-ink-400 hover:bg-parchment-300"
        >
          Reset
        </button>
      </div>
      <!-- Sort + search row -->
      <div class="mt-3 flex flex-wrap items-center gap-3 border-t border-parchment-300/40 pt-3">
        <label class="flex items-center gap-1.5 text-xs">
          <span class="text-ink-400">Triediť / <span class="italic" lang="en">Sort</span></span>
          <select
            id="filter-sort"
            lang="en"
            class="rounded border border-parchment-300 bg-parchment-50 px-2 py-1 font-sans text-xs"
          >
            <option value="default">Trust (FACTUAL → INTERPRETIVE → DEFERRED)</option>
            <option value="pair_id">Pair ID (PAIR_001 →)</option>
            <option value="evidentiary">Evidentiary strength</option>
            <option value="verification">Verification status</option>
            <option value="chapter">Chapter section</option>
          </select>
        </label>
        <label class="flex items-center gap-1.5 text-xs">
          <span class="text-ink-400">Hľadať / <span class="italic" lang="en">Search</span></span>
          <input
            id="filter-search"
            type="search"
            lang="en"
            placeholder="incipit, source ID, pair ID …"
            class="rounded border border-parchment-300 bg-parchment-50 px-2 py-1 font-sans text-xs w-56"
          />
        </label>
      </div>
      <p
        id="filter-status"
        class="mt-2 font-sans text-[11px] text-ink-300"
        aria-live="polite"
      >
        Zobrazené: {counts.total} z {counts.total}
      </p>
    </div>
  </div>

  <!-- ═══════════ DOSSIERS (grouped by mode) ═══════════ -->
  <div class="mx-auto max-w-wide px-6 py-8">
    <div id="pairs-list">
      {MODE_ORDER.filter((m) => pairsByMode[m].length > 0).map((mode, modeIdx) => (
        <section
          class:list={[
            "mode-group",
            modeIdx > 0 && "mt-10",
          ]}
          data-mode-group={mode}
          aria-labelledby={`mode-heading-${mode}`}
        >
          <div class="mode-group-header mb-5 border-b-2 border-parchment-300/60 pb-3">
            <div class="flex flex-wrap items-baseline justify-between gap-2">
              <h2
                id={`mode-heading-${mode}`}
                class="font-display text-lg font-semibold text-ink"
              >
                {MODE_LABELS[mode].sk}
              </h2>
              <span class="font-sans text-[11px] uppercase tracking-wider text-ink-300">
                {pairsByMode[mode].length} {pairsByMode[mode].length === 1 ? "pár" : pairsByMode[mode].length < 5 ? "páry" : "párov"} / <span lang="en">{pairsByMode[mode].length} pair{pairsByMode[mode].length === 1 ? "" : "s"}</span>
              </span>
            </div>
            <p class="mt-0.5 font-sans text-xs italic text-ink-300" lang="en">
              {MODE_LABELS[mode].en}
            </p>
            <p class="mt-2 max-w-3xl text-sm text-ink-400">
              {MODE_DESCRIPTIONS[mode].sk}
            </p>
            <p class="mt-1 max-w-3xl font-sans text-xs italic text-ink-300" lang="en">
              {MODE_DESCRIPTIONS[mode].en}
            </p>
          </div>
          <div class="space-y-6">
            {pairsByMode[mode].map((view) => {
              const p = view.pair;
              const transferLabel = TRANSFER_DIRECTION_LABELS[p.transfer_direction];
              const evidLabel = EVIDENTIARY_LABELS[p.evidentiary_strength];
              const verifLabel = VERIFICATION_LABELS[p.verification_status];
              const eLabel = epistemicLabels[p.epistemic_status];
              const isFlagged =
                p.evidentiary_strength === "CONJECTURED" ||
                p.verification_status === "UNVERIFIED";
              const sourcePending = view.source && isPlaceholderText(view.source.text_snippet ?? "");
              const receptorPending = view.receptor && isPlaceholderText(view.receptor.text_snippet ?? "");
              return (
                <article
                  class:list={[
                    "card scroll-mt-24",
                    epistemicClasses[p.epistemic_status],
                    isFlagged && "relative",
                  ]}
                  id={p.pair_id}
                  data-epistemic={p.epistemic_status}
                  data-evidentiary={p.evidentiary_strength}
                  data-verification={p.verification_status}
                  data-direction={p.transfer_direction}
                  data-mode={view.mode}
                >
              {/* Flag banner for unverified/conjectured pairs */}
              {isFlagged && (
                <div class="-mx-6 -mt-6 mb-4 rounded-t-lg bg-burgundy/10 px-6 py-2">
                  <p class="font-sans text-xs font-semibold uppercase tracking-wider text-burgundy">
                    &#x26A0;&#xFE0F; Výskumný cieľ — verifikácia v procese / <span lang="en">Research target — verification in progress</span>
                  </p>
                </div>
              )}

              {/* Header */}
              <header class="border-b border-parchment-300/40 pb-4">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="flex-1">
                    <p class="font-mono text-[10px] font-medium tracking-wider text-ink-300">
                      {p.pair_id}
                      {p.chapter_section && ` · ${p.chapter_section}`}
                    </p>
                    <h3 class="mt-1 font-display text-lg font-semibold text-ink">
                      {p.pair_label_sk}
                    </h3>
                    <p class="mt-0.5 font-sans text-xs italic text-ink-300" lang="en">
                      {p.pair_label_en}
                    </p>
                  </div>
                  {/* Trust axes */}
                  <div class="flex flex-col items-end gap-1.5">
                    <span class="rounded-full bg-parchment-200 px-2 py-0.5 font-sans text-[10px] text-ink-400">
                      {eLabel.sk} / <span class="italic" lang="en">{eLabel.en}</span>
                    </span>
                    <span
                      class:list={[
                        "rounded-full px-2 py-0.5 font-sans text-[10px] font-medium",
                        evidentiaryRing[p.evidentiary_strength],
                      ]}
                    >
                      {evidLabel.sk} / <span class="italic" lang="en">{evidLabel.en}</span>
                    </span>
                    <span
                      class:list={[
                        "rounded-full px-2 py-0.5 font-sans text-[10px] font-semibold",
                        verificationBadge[p.verification_status],
                      ]}
                    >
                      {verifLabel.sk} / <span class="italic" lang="en">{verifLabel.en}</span>
                    </span>
                  </div>
                </div>

                {/* Locus + transfer + modifications */}
                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <span
                    class="rounded-full bg-gold/15 px-2 py-0.5 font-mono text-[10px] font-medium text-gold-dark"
                    title={view.primaryLocusEn}
                  >
                    {view.primaryLocusName}
                    {view.primaryLocusEn && (
                      <span class="ml-1 italic opacity-80" lang="en">
                        / {view.primaryLocusEn}
                      </span>
                    )}
                  </span>
                  {transferLabel && (
                    <span class="rounded-full bg-parchment-300/50 px-2 py-0.5 font-sans text-[10px] text-ink-400">
                      &#x2192; {transferLabel.sk} / <span class="italic" lang="en">{transferLabel.en}</span>
                    </span>
                  )}
                  {view.modificationTypes.map((m) => (
                    <span class="rounded-full bg-burgundy/10 px-2 py-0.5 font-mono text-[10px] text-burgundy">
                      {m}
                    </span>
                  ))}
                </div>
              </header>

              {/* Source ↔ Receptor strip */}
              {(view.source || view.receptor) && (
                <div class="my-4 grid gap-3 md:grid-cols-2">
                  {view.source && (
                    <div class:list={[
                      "rounded-md border-l-4 p-3",
                      view.source.tradition === "UTRAQUIST" && "border-utraquist bg-utraquist/5",
                      view.source.tradition === "UNITY" && "border-unity bg-unity/5",
                      view.source.tradition === "LUTHERAN" && "border-lutheran bg-lutheran/5",
                    ]}>
                      <p class="font-sans text-[10px] uppercase tracking-wider text-ink-300">
                        Zdroj / <span lang="en">Source</span>
                      </p>
                      <p class="mt-1 font-display font-semibold text-ink">
                        {view.source.incipit}
                      </p>
                      <p class="mt-0.5 font-sans text-xs text-ink-400">
                        <a
                          href={`${baseN}/sources/#${view.source.source_collection_id}`}
                          class="hover:text-burgundy"
                        >
                          {view.source.source_collection_id}
                        </a>
                        {view.source.source_number && ` · ${view.source.source_number}`}
                      </p>
                      {sourcePending && (
                        <p class="mt-2 rounded bg-burgundy/5 px-2 py-1 font-sans text-[10px] italic text-burgundy/80">
                          &#x231A; Plný text čaká na priamu kolaciu / <span lang="en">Full text pending direct collation</span>
                        </p>
                      )}
                      <div class="mt-2">
                        <TraditionBadge tradition={view.source.tradition} size="sm" />
                      </div>
                    </div>
                  )}
                  {view.receptor && (
                    <div class:list={[
                      "rounded-md border-l-4 p-3",
                      view.receptor.tradition === "UTRAQUIST" && "border-utraquist bg-utraquist/5",
                      view.receptor.tradition === "UNITY" && "border-unity bg-unity/5",
                      view.receptor.tradition === "LUTHERAN" && "border-lutheran bg-lutheran/5",
                    ]}>
                      <p class="font-sans text-[10px] uppercase tracking-wider text-ink-300">
                        Recepcia / <span lang="en">Receptor</span>
                      </p>
                      <p class="mt-1 font-display font-semibold text-ink">
                        {view.receptor.incipit}
                      </p>
                      <p class="mt-0.5 font-sans text-xs text-ink-400">
                        <a
                          href={`${baseN}/sources/#${view.receptor.source_collection_id}`}
                          class="hover:text-burgundy"
                        >
                          {view.receptor.source_collection_id}
                        </a>
                        {view.receptor.source_number && ` · ${view.receptor.source_number}`}
                      </p>
                      {receptorPending && (
                        <p class="mt-2 rounded bg-burgundy/5 px-2 py-1 font-sans text-[10px] italic text-burgundy/80">
                          &#x231A; Plný text čaká na priamu kolaciu / <span lang="en">Full text pending direct collation</span>
                        </p>
                      )}
                      <div class="mt-2">
                        <TraditionBadge tradition={view.receptor.tradition} size="sm" />
                      </div>
                    </div>
                  )}
                </div>
              )}

              {/* Theological argument */}
              <div class="mt-4">
                <h4 class="font-sans text-xs font-semibold uppercase tracking-wider text-ink-300">
                  Teologický argument / <span lang="en">Theological Argument</span>
                </h4>
                <p class="mt-2 font-serif text-sm leading-relaxed text-ink-400">
                  {p.theological_argument_sk}
                </p>
                <p class="mt-3 font-sans text-xs italic leading-relaxed text-ink-300" lang="en">
                  {p.theological_argument_en}
                </p>
              </div>

              {/* Citation chain */}
              {view.citationIds.length > 0 && (
                <div class="mt-4 rounded-md bg-parchment-100/70 p-3">
                  <h4 class="font-sans text-xs font-semibold uppercase tracking-wider text-ink-300">
                    Citačný reťazec / <span lang="en">Citation Chain</span>
                  </h4>
                  <ul class="mt-2 list-disc space-y-1 pl-5 font-mono text-xs text-ink-400">
                    {view.citationIds.map((id) => (
                      <li>
                        <a
                          href={`${baseN}/sources/#${id}`}
                          class="hover:text-burgundy"
                        >
                          {id}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}

              {/* Methodological notes */}
              {(p.notes_sk || p.notes_en) && (
                <details class="group mt-4">
                  <summary class="cursor-pointer font-sans text-xs font-semibold uppercase tracking-wider text-ink-400 hover:text-burgundy">
                    Metodologické poznámky / <span lang="en">Methodological Notes</span>
                    <span class="ml-1 inline-block transition-transform group-open:rotate-90">
                      &#x25B8;
                    </span>
                  </summary>
                  <div class="mt-2 rounded-md border border-parchment-300/50 bg-parchment-50 p-3">
                    {p.notes_sk && (
                      <p class="font-serif text-sm leading-relaxed text-ink-400">
                        {p.notes_sk}
                      </p>
                    )}
                    {p.notes_en && (
                      <p class="mt-2 font-sans text-xs italic leading-relaxed text-ink-300" lang="en">
                        {p.notes_en}
                      </p>
                    )}
                  </div>
                </details>
              )}

              {/* How to cite this pair */}
              <details class="group mt-3">
                <summary class="cursor-pointer font-sans text-xs font-semibold uppercase tracking-wider text-ink-400 hover:text-burgundy">
                  Ako citovať / <span lang="en">How to cite this pair</span>
                  <span class="ml-1 inline-block transition-transform group-open:rotate-90">
                    &#x25B8;
                  </span>
                </summary>
                <div class="mt-2 space-y-3 rounded-md border border-parchment-300/50 bg-parchment-50 p-3">
                  <div>
                    <p class="font-sans text-[10px] uppercase tracking-wider text-ink-300">
                      APA
                    </p>
                    <p class="mt-1 font-serif text-xs leading-relaxed text-ink-400" lang="en">
                      {view.apa}
                    </p>
                  </div>
                  <div>
                    <p class="font-sans text-[10px] uppercase tracking-wider text-ink-300">
                      BibTeX
                    </p>
                    <pre class="mt-1 overflow-x-auto rounded bg-ink/5 p-2 font-mono text-[10px] text-ink"><code>{view.bibtex}</code></pre>
                  </div>
                  <div>
                    <p class="font-sans text-[10px] uppercase tracking-wider text-ink-300">
                      Permalink
                    </p>
                    <p class="mt-1 break-all font-mono text-[10px] text-ink-400">
                      <a href={`#${p.pair_id}`} class="hover:text-burgundy">
                        {view.permalink}
                      </a>
                    </p>
                  </div>
                </div>
              </details>

              {/* Cross-links */}
              <footer class="mt-4 flex flex-wrap gap-2 border-t border-parchment-300/40 pt-3">
                {p.synoptikon_id && (
                  <a
                    href={`${baseN}/synoptikon/#comparison-${p.synoptikon_id}`}
                    class="inline-flex items-center gap-1 rounded-md bg-gold/15 px-2.5 py-1 font-sans text-xs font-medium text-gold-dark no-underline transition-colors hover:bg-gold/25"
                  >
                    Synoptikon &#x2192;
                  </a>
                )}
                {/* Currently only PAIR_006 has a per-pair diff page; the pair-id
                    check stays inline until additional diff pages exist (per the
                    strategy doc, ~6–8 hours per subsequent pair). */}
                {p.pair_id === "PAIR_006_AC_BA_EUCHARIST" && (
                  <a
                    href={`${baseN}/diff/pair-006/`}
                    class="inline-flex items-center gap-1 rounded-md bg-burgundy/10 px-2.5 py-1 font-sans text-xs font-medium text-burgundy no-underline transition-colors hover:bg-burgundy/20"
                  >
                    Register-shift diff &#x2192;
                  </a>
                )}
                {(p.source_text_id || p.receptor_text_id) && (
                  <span class="inline-flex items-center gap-1 rounded-md bg-parchment-300/50 px-2.5 py-1 font-mono text-[10px] text-ink-400">
                    Evidence rows:
                    {p.source_text_id && ` ${p.source_text_id}`}
                    {p.source_text_id && p.receptor_text_id && " · "}
                    {p.receptor_text_id && ` ${p.receptor_text_id}`}
                  </span>
                )}
              </footer>
                </article>
              );
            })}
          </div>
        </section>
      ))}
      <p
        id="pairs-empty"
        class="hidden rounded-md border border-dashed border-parchment-400 bg-parchment-100/50 p-6 text-center font-sans text-sm text-ink-400"
      >
        Žiadne hymno-páry nezodpovedajú filtrom. /
        <span lang="en">No hymn pairs match the current filters.</span>
      </p>
    </div>
  </div>

  <div class="ornament-rule"></div>

  <!-- ═══════════ EPISTEMIC LEGEND ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-8">
    <div class="mx-auto max-w-2xl">
      <EpistemicLegend />
    </div>
  </section>

  <!-- ═══════════ HOW THIS WORKS ═══════════ -->
  <section class="mx-auto max-w-content px-6 py-8 pb-20">
    <h2 class="text-center text-section-title text-ink">Ako sa tento dossier čítá</h2>
    <p class="mx-auto mt-3 max-w-prose text-center font-sans text-sm italic text-ink-300" lang="en">
      How this dossier reads
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      <div class="card">
        <h3 class="font-display text-base font-semibold text-ink">
          Tri nezávislé osi dôvery
        </h3>
        <p class="mt-1 font-sans text-xs italic text-ink-300" lang="en">
          Three independent trust axes
        </p>
        <p class="mt-3 text-sm text-ink-400">
          Tvrdenie môže byť <em>doložené</em> v literatúre (Documented), no projekt
          ho ešte sám neskolacionoval (Secondary only). Naopak, môže byť <em>vlastná</em>
          analýza (Inferred) podporená priamym overením textov (Verified). Tri osi
          umožňujú toto rozlíšiť — netradičné, ale nutné pre digitálnu humanistiku.
        </p>
        <p class="mt-3 font-sans text-xs italic text-ink-300" lang="en">
          A claim may be <em>documented</em> in the literature yet not <em>verified</em> by
          our own collation. Conversely, an own-analysis claim may be supported by
          direct textual verification. Three axes let us distinguish — uncommon, but
          essential for digital humanities.
        </p>
      </div>
      <div class="card">
        <h3 class="font-display text-base font-semibold text-ink">
          Vzťah k Synoptikonu
        </h3>
        <p class="mt-1 font-sans text-xs italic text-ink-300" lang="en">
          Relationship to the Synoptikon
        </p>
        <p class="mt-3 text-sm text-ink-400">
          Synoptikon zobrazuje paralelné texty bok po boku — je vizuálnou stránkou
          dôkazu. Hymno-páry sú jeho katalogizačná stránka: každý záznam má citačný
          reťazec, epistemické flagy a odkaz na zodpovedajúci Synoptikon (ak existuje).
        </p>
        <p class="mt-3 font-sans text-xs italic text-ink-300" lang="en">
          The Synoptikon displays parallel texts side by side — the visual face of the
          evidence. Hymn-Pairs is its catalogue face: each record carries a citation
          chain, epistemic flags, and a link to the corresponding Synoptikon view (if any).
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  /* ── Print stylesheet ──
     Scholarly users print pair dossiers for offline review. The print version
     should: hide site chrome (header / footer / filter bar); flatten interactive
     elements (expand all <details>); preserve trust badges and citation chains;
     use serif body text for readability.

     `is:global` is required because we need to target elements rendered by
     imported components (Header, Footer) which carry different Astro scope IDs.
     The rules only activate on /hymn-pairs/ since this <style> tag is only
     emitted for that route. */
  @media print {
    /* Page metadata: dataset DOI on every printed page */
    @page {
      margin: 18mm 16mm;
    }
    body {
      font-family: Georgia, "Times New Roman", serif;
      font-size: 10.5pt;
      line-height: 1.4;
      color: #000;
      background: #fff;
    }
    /* Hide site chrome and interactive controls */
    header,
    footer,
    .synoptikon-toggle,
    nav[aria-label="Main navigation"],
    nav[aria-label="Mobile navigation"],
    #mobile-menu-btn,
    /* Filter bar block */
    .max-w-wide > .rounded-lg.border,
    /* Stat cards row */
    .max-w-wide > .grid.grid-cols-2,
    /* Hero section */
    .bg-ink-800,
    /* Trust-axes legend */
    .max-w-wide > .rounded-lg.bg-parchment-100\/60,
    /* "How this dossier reads" + epistemic legend at bottom */
    .ornament-rule,
    .ornament-rule + section,
    .ornament-rule ~ section {
      display: none !important;
    }
    /* Expand all details so notes/citations print inline */
    details {
      page-break-inside: avoid;
    }
    details > summary {
      list-style: none;
      cursor: default;
    }
    details > summary::-webkit-details-marker {
      display: none;
    }
    details[open] > * {
      display: block !important;
    }
    /* Ensure all collapsed sections print as expanded */
    details:not([open]) > *:not(summary) {
      display: block !important;
    }
    /* One pair per printed page when feasible */
    article[data-epistemic] {
      page-break-after: always;
      break-after: page;
      box-shadow: none;
      border: 1px solid #000;
      padding: 14pt;
    }
    article[data-epistemic]:last-child {
      page-break-after: auto;
    }
    /* Hidden filter-state items must NOT print */
    .hidden {
      display: none !important;
    }
    /* Expand BibTeX <pre> to fit page width */
    pre {
      white-space: pre-wrap;
      word-break: break-word;
      font-size: 8pt;
    }
    /* Avoid breaking inside cards/sources */
    .card {
      page-break-inside: avoid;
    }
    /* Print-only attribution on every page (using @page is unreliable in
       browsers; use a per-pair footer instead via CSS counter trick is overkill;
       simplest approach: rely on browser's URL-in-footer setting). */
  }
</style>

<script is:inline>
  // ── Filter bar ──
  const filters = {
    mode: document.getElementById("filter-mode"),
    epistemic: document.getElementById("filter-epistemic"),
    evidentiary: document.getElementById("filter-evidentiary"),
    verification: document.getElementById("filter-verification"),
    direction: document.getElementById("filter-direction"),
  };
  const sortSel = document.getElementById("filter-sort");
  const searchInp = document.getElementById("filter-search");
  const reset = document.getElementById("filter-reset");
  const status = document.getElementById("filter-status");
  const empty = document.getElementById("pairs-empty");
  const list = document.getElementById("pairs-list");
  const articles = list ? Array.from(list.querySelectorAll("article[data-epistemic]")) : [];
  const modeGroups = list ? Array.from(list.querySelectorAll("section[data-mode-group]")) : [];
  const total = articles.length;

  // Pre-compute lowercase search-text for each article (id + visible text).
  // Avoids re-reading textContent on every keystroke.
  const articleSearchText = new Map();
  articles.forEach(function (a) {
    articleSearchText.set(a, ((a.id || "") + " " + (a.textContent || "")).toLowerCase());
  });

  // Sort comparators. With mode-primary grouping, sorts operate WITHIN each
  // mode group rather than flattening across groups. "default" preserves the
  // server-side build order (FACTUAL → INTERPRETIVE → DEFERRED inside each
  // mode). Other modes re-order siblings inside each mode group's child container.
  const evidentiaryOrder = { DOCUMENTED: 0, INFERRED: 1, CONJECTURED: 2 };
  const verificationOrder = { VERIFIED: 0, PRIMARY_PENDING: 1, SECONDARY_ONLY: 2, UNVERIFIED: 3 };

  // Capture the per-group original child order at script init so we can
  // restore it for the "default" mode without re-querying the DOM.
  const groupOriginalOrder = new Map();
  modeGroups.forEach(function (group) {
    const inner = group.querySelector("div.space-y-6");
    if (!inner) return;
    groupOriginalOrder.set(group, Array.from(inner.children));
  });

  function applySort(mode) {
    modeGroups.forEach(function (group) {
      const inner = group.querySelector("div.space-y-6");
      if (!inner) return;
      const groupArticles = Array.from(inner.querySelectorAll("article[data-epistemic]"));
      let sorted;
      if (mode === "pair_id") {
        sorted = groupArticles.slice().sort(function (a, b) { return (a.id || "").localeCompare(b.id || ""); });
      } else if (mode === "evidentiary") {
        sorted = groupArticles.slice().sort(function (a, b) {
          return (evidentiaryOrder[a.dataset.evidentiary] ?? 99) - (evidentiaryOrder[b.dataset.evidentiary] ?? 99);
        });
      } else if (mode === "verification") {
        sorted = groupArticles.slice().sort(function (a, b) {
          return (verificationOrder[a.dataset.verification] ?? 99) - (verificationOrder[b.dataset.verification] ?? 99);
        });
      } else if (mode === "chapter") {
        sorted = groupArticles.slice().sort(function (a, b) {
          const aSec = (a.textContent.match(/§[0-9.]+/) || [""])[0];
          const bSec = (b.textContent.match(/§[0-9.]+/) || [""])[0];
          return aSec.localeCompare(bSec);
        });
      } else {
        const original = groupOriginalOrder.get(group);
        sorted = original ? original.slice() : groupArticles.slice();
      }
      sorted.forEach(function (a) { inner.appendChild(a); });
    });
  }

  function applyFilters() {
    if (!status) return;
    const m = filters.mode && filters.mode.value;
    const e = filters.epistemic && filters.epistemic.value;
    const ev = filters.evidentiary && filters.evidentiary.value;
    const v = filters.verification && filters.verification.value;
    const d = filters.direction && filters.direction.value;
    const q = searchInp && searchInp.value ? searchInp.value.trim().toLowerCase() : "";
    let visible = 0;
    articles.forEach(function (a) {
      const ok =
        (!m || a.dataset.mode === m) &&
        (!e || a.dataset.epistemic === e) &&
        (!ev || a.dataset.evidentiary === ev) &&
        (!v || a.dataset.verification === v) &&
        (!d || a.dataset.direction === d) &&
        (!q || (articleSearchText.get(a) || "").indexOf(q) !== -1);
      a.classList.toggle("hidden", !ok);
      if (ok) visible++;
    });
    // Hide mode group sections whose articles are all filtered out, so the
    // section header does not float over an empty space.
    modeGroups.forEach(function (group) {
      const groupArticles = Array.from(group.querySelectorAll("article[data-epistemic]"));
      const anyVisible = groupArticles.some(function (a) {
        return !a.classList.contains("hidden");
      });
      group.classList.toggle("hidden", !anyVisible);
    });
    status.textContent = "Zobrazené: " + visible + " z " + total;
    if (empty) empty.classList.toggle("hidden", visible !== 0);
  }

  Object.values(filters).forEach(function (el) {
    if (el) el.addEventListener("change", applyFilters);
  });
  if (sortSel) {
    sortSel.addEventListener("change", function () { applySort(sortSel.value); });
  }
  if (searchInp) {
    // Debounce keystroke handling so layout doesn't thrash.
    let t;
    searchInp.addEventListener("input", function () {
      clearTimeout(t);
      t = setTimeout(applyFilters, 120);
    });
  }
  if (reset) {
    reset.addEventListener("click", function () {
      Object.values(filters).forEach(function (el) {
        if (el) el.value = "";
      });
      if (sortSel) sortSel.value = "default";
      if (searchInp) searchInp.value = "";
      applySort("default");
      applyFilters();
    });
  }
</script>
