cff-version: 1.2.0
title: "TEPALIT Digital Companion: Theological Taxonomy and Hymn-Pair Dossier for the Lutheranisation Thesis"
message: "If you use this dataset, taxonomy, or any individual hymn-pair dossier, please cite it as below."
type: dataset
version: 0.1.0
date-released: "2026-05-08"
